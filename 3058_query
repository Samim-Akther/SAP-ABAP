CLEAR : ZBELNR.
*AM BOM 03.04.2026 7581
data ls_bkpf type bkpf.
select single * from bkpf into ls_bkpf
  where
  bukrs = vbrk-bukrs and
  xblnr = vbrk-vbeln and
  gjahr = vbrk-fkdat(4).
  if sy-subrc = 0.
    select single BELNR
      from BSID
      into ZBELNR
      where
      VBELN = VBRK-VBELN and
      bukrs = ls_bkpf-bukrs and
      belnr = ls_bkpf-belnr and
      gjahr = ls_bkpf-gjahr.
      if sy-subrc ne 0.
         select single BELNR
      from BSAD
      into ZBELNR
      where
      VBELN = VBRK-VBELN and
      bukrs = ls_bkpf-bukrs and
      belnr = ls_bkpf-belnr and
      gjahr = ls_bkpf-gjahr.
      endif.
    endif.
