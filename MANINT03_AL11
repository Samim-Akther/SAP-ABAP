TYPES: BEGIN OF ty_machine_out,
         machine_code        TYPE c LENGTH 2,
         machine_serial_no   TYPE c LENGTH 10,
         machine_position    TYPE c LENGTH 10,
         machine_description TYPE c LENGTH 50,
         productivity        TYPE p LENGTH 5 DECIMALS 0,
         iud_flag            TYPE c LENGTH 1,
       END OF ty_machine_out.

CONSTANTS:lc_default_werks TYPE werks_d VALUE 'UK01',
          lc_default_zpal  TYPE zpal VALUE '03',
          lv_format        TYPE string VALUE 'CSV',
          lc_a             TYPE cr_objty VALUE 'A',
          lc_machine       TYPE string VALUE 'MACHINE',
          lc_chrd          TYPE tabelle VALUE 'CRHD',
          lc_zmachine      TYPE klasse_d VALUE 'ZMACHINE',
          lc_019           TYPE klassenart VALUE '019',
          lc_zmach_code    TYPE atnam VALUE 'ZMACH_CODE',
          lc_progname      TYPE progname VALUE
                                         'ZPPIO_MACHINE_SAP_TO_TRASCAR',
          lc_name          TYPE rvari_vnam VALUE 'ZPAL_TRASCAR',
          lc_name1         TYPE rvari_vnam VALUE 'WERKS',
          lc_name2         TYPE rvari_vnam VALUE 'ZDELIMITER-UK01',
          lc_progname2     TYPE progname VALUE 'ZLIIN_PRO',
          lc_type          TYPE rsscr_kind VALUE 'S',
          lc_msg_type(1)   TYPE c VALUE 'E',
          lc_zrename       TYPE sxpgcolist-name VALUE 'ZRENAME',
          lc_new_format    TYPE string VALUE '.in',
          lc_old_format    TYPE string VALUE '.csv',
          lc_0             TYPE char1 VALUE '0',
          lc_1             TYPE char1 VALUE '1'.


DATA: lt_output          TYPE TABLE OF ty_machine_out,
      ls_output          TYPE ty_machine_out,
      lo_manager         TYPE REF TO zcl_data_export_utility,
      lr_data            TYPE REF TO data,
      lv_filename        TYPE string,
      lv_directory       TYPE string,
      lv_werks           TYPE zlpalletizer-werks,
      lv_zpal            TYPE zlpalletizer-zpal,
      lt_path_range      TYPE TABLE OF hrranges,
      lv_presult         TYPE char1,
      lv_path            TYPE string,
      rv_msg             TYPE string,
      lt_allocvaluesnum  TYPE TABLE OF bapi1003_alloc_values_num,
      lt_allocvalueschar TYPE TABLE OF bapi1003_alloc_values_char,
      lt_allocvaluescurr TYPE TABLE OF bapi1003_alloc_values_curr,
      lt_return          TYPE TABLE OF bapiret2,
      lv_file_path       TYPE string,
      lv_lvorm           TYPE crhd-lvorm.

CALL FUNCTION 'ZXUN_GET_PARAMETER_YSVARV'
  EXPORTING
    i_progname      = lc_progname2
    i_name          = lc_name2
  IMPORTING
    p_result        = lv_presult
  EXCEPTIONS
    wrong_type      = 1
    wrong_value     = 2
    inchoerent_type = 3
    OTHERS          = 4.
IF sy-subrc <> 0.
  CLEAR lv_presult.
ENDIF.

TYPES: BEGIN OF ty_crhd,
         objty TYPE crhd-objty,
         objid TYPE crhd-objid,
         arbpl TYPE crhd-arbpl,
         stand TYPE crhd-stand,
         werks TYPE crhd-werks,
         lvorm TYPE crhd-lvorm,
       END OF ty_crhd.

DATA: lt_crhd TYPE STANDARD TABLE OF ty_crhd WITH EMPTY KEY.



SELECTION-SCREEN BEGIN OF BLOCK b1 WITH FRAME.

SELECT-OPTIONS:
               s_werks FOR lv_werks OBLIGATORY DEFAULT lc_default_werks,
               s_zpal  FOR lv_zpal  OBLIGATORY DEFAULT lc_default_zpal,
               s_lvorm FOR lv_lvorm.
SELECTION-SCREEN END OF BLOCK b1.

