INCLUDE zpipo_machinetotrascar_subrtn.

INITIALIZATION.
DATA(lo_obj) = NEW machine( ).

AT SELECTION-SCREEN.
  if lo_obj is BOUND.
  lo_obj->validation( ).
ENDIF.

