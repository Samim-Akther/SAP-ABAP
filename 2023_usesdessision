*&---------------------------------------------------------------------*
*&      Form  F_GET_DATA
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM f_get_data .
  REFRESH gt_output.
  SELECT prueflos,
         werk,
         art,
         stat35,
         enstehdat,
         matnr,
         charg,
         lagortchrg,
         ls_vbeln,
         ls_vkorg,
         losmenge,
         einhprobe FROM qals INTO TABLE @DATA(lt_qals)
         WHERE  prueflos IN @s_insno
         AND matnr IN @s_matnr
         AND enstehdat IN @s_credt
         AND ls_vbeln IN @s_vbeln
         AND ls_vkorg IN @s_vkorg
         AND art IN @lt_harranges_art
         AND werk IN @lt_harranges_plant
         AND stat35 = @space.

  IF sy-subrc = 0 AND lt_qals IS NOT INITIAL.
    SORT: lt_qals BY prueflos.
    SELECT venum,
           vepos,
           qplos FROM vepo INTO TABLE @DATA(lt_vepo)
           FOR ALL ENTRIES IN @lt_qals
           WHERE qplos =  @lt_qals-prueflos.

    IF sy-subrc = 0 AND lt_vepo IS NOT INITIAL.
      SORT lt_vepo BY venum.
      SELECT venum,
             exidv,
             exidv2 FROM vekp INTO TABLE @DATA(lt_vekp)
             FOR ALL ENTRIES IN @lt_vepo
             WHERE venum = @lt_vepo-venum.
      SORT lt_vekp BY venum.
    ENDIF.

    SORT: lt_qals BY matnr.
    SELECT matnr,
           spras,
           maktx FROM makt INTO TABLE @DATA(lt_makt)
           FOR ALL ENTRIES IN @lt_qals
           WHERE matnr = @lt_qals-matnr
           AND spras = @sy-langu.
    IF sy-subrc = 0.
      SORT: lt_makt BY matnr.
    ENDIF.
  ELSE .
    MESSAGE text-023 TYPE gc_type_e.
  ENDIF.

  SORT: lt_vepo BY qplos.
  LOOP AT lt_qals INTO DATA(ls_qals).
    READ TABLE lt_vepo INTO DATA(ls_vepo)
        WITH KEY qplos = ls_qals-prueflos
        BINARY SEARCH.
    IF sy-subrc = 0.
      READ TABLE lt_vekp INTO DATA(ls_vekp)
          WITH KEY venum = ls_vepo-venum
          BINARY SEARCH.
      IF sy-subrc = 0.
        gs_output-exidv     = ls_vekp-exidv.
        gs_output-exidv2    = ls_vekp-exidv2.
      ENDIF.
    ENDIF.
    READ TABLE lt_makt INTO DATA(ls_makt)
          WITH KEY matnr = ls_qals-matnr
          BINARY SEARCH.
    IF sy-subrc = 0.
      gs_output-maktx     = ls_makt-maktx.
    ENDIF.

    gs_output-prueflos  = ls_qals-prueflos.
    gs_output-enstehdat = ls_qals-enstehdat.
    gs_output-matnr     = ls_qals-matnr.
    gs_output-charg     = ls_qals-charg.
    gs_output-vkorg     = ls_qals-ls_vkorg.
    gs_output-losmenge  = ls_qals-losmenge.
    gs_output-posting   = space.
    gs_output-drdn_hdl = 1.
    gs_output-plant    = ls_qals-werk.
    gs_output-strg_loc  = ls_qals-lagortchrg.
    gs_output-uom    =   ls_qals-einhprobe.
    APPEND gs_output TO gt_output.
    CLEAR: gs_output.
  ENDLOOP.

ENDFORM.
