*&      Form  F_CHECK_MATNR
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*

FORM f_check_matnr .
  SELECT matnr
    FROM mara
    INTO TABLE @DATA(lt_mara)
   WHERE matnr IN @s_matnr.
  LOOP AT s_matnr INTO DATA(ls_matnr).
    IF ls_matnr-low IS NOT INITIAL.
      READ TABLE lt_mara WITH KEY matnr = ls_matnr-low TRANSPORTING NO FIELDS.
      IF sy-subrc <> 0.
        MESSAGE text-012 TYPE gc_type_e.
      ENDIF.
    ENDIF.

    IF ls_matnr-high IS NOT INITIAL.
      READ TABLE lt_mara WITH KEY matnr = ls_matnr-high TRANSPORTING NO FIELDS.
      IF sy-subrc <> 0.
        MESSAGE text-012 TYPE gc_type_e.
      ENDIF.
    ENDIF.
  ENDLOOP.

ENDFORM.

