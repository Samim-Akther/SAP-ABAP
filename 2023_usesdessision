*&      Form  F__SETUSAGEDECISION
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM f__setusagedecision .

  LOOP AT gt_output ASSIGNING FIELD-SYMBOL(<ls_chk>) WHERE checkbox = abap_true.
    IF <ls_chk>-posting IS INITIAL.
      MESSAGE text-016 TYPE gc_type_e.
    ENDIF.
  ENDLOOP.

  LOOP AT gt_output ASSIGNING FIELD-SYMBOL(<ls_row>) WHERE checkbox = abap_true.

    CASE <ls_row>-posting.
      WHEN text-024. "Unrestricted
        gv_udcode = gv_unrestricted.
      WHEN text-025. "Scrap
        gv_udcode = gv_scrap.
    ENDCASE.


    CLEAR: general_data,
           task_list_data,
           stock_data,
           accounting_data,
           usage_decision_data,
           customer_include_data,
           return_detail,
           system_status,
           user_status,
           material_documents,
           ls_ud_data,
           lv_langu,
           ls_return,
           lv_ud_return_data,
           lv_stock_data,
           lv_stock_data,
           lt_sys_stat,
           lt_usr_stat.


    gv_number = <ls_row>-prueflos.
    ls_ud_data-insplot              = gv_number.
    ls_ud_data-ud_selected_set      = gv_selset.
    ls_ud_data-ud_plant             = <ls_row>-plant.
    ls_ud_data-ud_code_group        = gv_udgrp.
    ls_ud_data-ud_code              = gv_udcode.
    ls_ud_data-ud_force_completion  = gc_udforcecom.
    ls_ud_data-ud_stock_posting     = gc_udstlpost.


    CALL FUNCTION 'BAPI_INSPLOT_SETUSAGEDECISION'
      EXPORTING
        number         = gv_number
        ud_data        = ls_ud_data
        language       = lv_langu
      IMPORTING
        return         = ls_return
        ud_return_data = lv_ud_return_data
        stock_data     = lv_stock_data
      TABLES
        system_status  = lt_sys_stat
        user_status    = lt_usr_stat.

    DATA(lv_has_error) = abap_false.

    IF ls_return-type = gc_type_e OR ls_return-type = gc_type_a.
      lv_has_error = abap_true.
    ENDIF.
    IF lv_has_error = abap_true.
      CALL FUNCTION 'BAPI_TRANSACTION_ROLLBACK'.

      ls_err-id = gv_number.
      ls_err-message = ls_return-message.
      APPEND ls_err TO lt_err.
      CLEAR ls_err.

    ELSE.
      CALL FUNCTION 'BAPI_TRANSACTION_COMMIT'
        EXPORTING
          wait = gc_x.
      APPEND VALUE ty_success_sel(
               sign   = gc_I
               option = gc_eq
               low    = gv_number
               high   = gv_number
             ) TO lt_success.

      CLEAR:gv_number.
    ENDIF.

  ENDLOOP.
  " Remove duplicates
  IF lt_success IS NOT INITIAL.
    SORT lt_success BY low.
    DELETE ADJACENT DUPLICATES FROM lt_success COMPARING low.
  ENDIF.

  IF lt_err IS NOT INITIAL.
    SORT lt_err BY id message.
    DELETE ADJACENT DUPLICATES FROM lt_err COMPARING id message.
  ENDIF.

  IF lt_success IS NOT INITIAL.
    DELETE gt_output WHERE prueflos IN lt_success.
    DATA(ls_stbl) = VALUE lvc_s_stbl( row = abap_true col = abap_true ).
    IF go_grid IS BOUND.
      go_grid->refresh_table_display( EXPORTING is_stable = ls_stbl ).
    ENDIF.
  ENDIF.
  PERFORM f_show_summary USING lt_success lt_err.
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  F_SHOW_SUMMARY
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_LT_SUCCESS  text
*      -->P_LT_ERR  text
*----------------------------------------------------------------------*
FORM f_show_summary  USING
                          it_success TYPE  ty_success_tab
                          it_err     TYPE  ty_err_tab.

  LEAVE TO LIST-PROCESSING AND RETURN TO SCREEN 100.
  NEW-PAGE.
  WRITE: / text-019, /.

  WRITE: / text-018.
  LOOP AT it_success ASSIGNING FIELD-SYMBOL(<ls_success>).
    WRITE: / | { text-027 } { <ls_success>-low } { text-026 } |.
  ENDLOOP.
  SKIP.
  WRITE: / text-017.
  LOOP AT it_err ASSIGNING FIELD-SYMBOL(<ls_error>).
    WRITE: / |{ text-027 } { <ls_error>-id } { text-028 } { <ls_error>-message }|.
  ENDLOOP.
ENDFORM.
