*"----------------------------------------------------------------------
*"*"Lokale Schnittstelle:
*"  IMPORTING
*"     REFERENCE(IM_HEADER) TYPE REF TO  IF_PURCHASE_ORDER_MM
*"     REFERENCE(IM_ITEM) TYPE REF TO  IF_PURCHASE_ORDER_ITEM_MM
*"     REFERENCE(IM_INITIATOR) TYPE  MEPO_INITIATOR OPTIONAL
*"  CHANGING
*"     REFERENCE(CH_FIELDSELECTION) TYPE  TTYP_FIELDSELECTION_MM
*"----------------------------------------------------------------------
*
* define local data objects
  DATA: lo_badi           TYPE REF TO lcl_badi,
        lo_badi_ibs       TYPE REF TO me_process_po,
        lo_badi_cust      TYPE REF TO me_process_po_cust,
        ls_document       TYPE mepo_document,
        lt_fieldselection TYPE ttyp_fieldselection_mm.

  FIELD-SYMBOLS: <fs1> LIKE LINE OF lt_fieldselection,
                 <fs2> LIKE LINE OF lt_fieldselection.

*
* get local BAdI instance handler
  lo_badi = lcl_badi=>get_instance( ).
* instantiate SAP internal BAdI first, as it may have multiple implementations
  lo_badi_ibs ?= lo_badi->get_badi( lo_badi->mc_po_ibs ).
  ls_document-initiator = im_initiator.
  IF im_initiator IS INITIAL.
    PERFORM mepo_xpd_get_document
            IN PROGRAM saplmepo
            CHANGING ls_document.
  ENDIF.

  CALL BADI lo_badi_ibs->fieldselection_item
    EXPORTING
      im_header         = im_header
      im_item           = im_item
      im_initiator      = ls_document-initiator
    CHANGING
      ch_fieldselection = ch_fieldselection.
*
* instantiate customer BAdI -> only one active implementation allowed
  lo_badi_cust ?= lo_badi->get_badi( lo_badi->mc_po_cust ).
  IF lo_badi_cust IS BOUND.
* firewall
    LOOP AT ch_fieldselection ASSIGNING <fs1> WHERE metafield GE mmmfd_cust_01.
      INSERT <fs1> INTO TABLE lt_fieldselection.
    ENDLOOP.
    IF sy-subrc IS INITIAL.
      CALL BADI lo_badi_cust->fieldselection_item
        EXPORTING
          im_header         = im_header
          im_item           = im_item
        CHANGING
          ch_fieldselection = lt_fieldselection.
      LOOP AT lt_fieldselection ASSIGNING <fs2>.
        READ TABLE ch_fieldselection ASSIGNING <fs1> WITH TABLE KEY
                                metafield = <fs2>-metafield.
        IF sy-subrc IS INITIAL.
          <fs1>-fieldstatus = <fs2>-fieldstatus.
        ENDIF.
      ENDLOOP.
    ENDIF.
  ENDIF.

