                  ls_pricelist-vtweg   = COND #( WHEN <f_vtweg> IS ASSIGNED THEN <f_vtweg> ).
                  ls_pricelist-spart   = COND #( WHEN <f_spart> IS ASSIGNED THEN <f_spart> ).
                  ls_pricelist-kunnr   = COND #( WHEN <f_kunnr> IS ASSIGNED THEN <f_kunnr> ).
                  ls_pricelist-kunag   = COND #( WHEN <f_kunag> IS ASSIGNED THEN <f_kunag> ).
                  ls_pricelist-kunwe   = COND #( WHEN <f_kunwe> IS ASSIGNED THEN <f_kunwe> ).
                  ls_pricelist-inco1   = COND #( WHEN <f_inco1> IS ASSIGNED THEN <f_inco1> ).
                  ls_pricelist-vsbed   = COND #( WHEN <f_vsbed> IS ASSIGNED THEN <f_vsbed> ).
                  ls_pricelist-matnr   = COND #( WHEN <f_matnr> IS ASSIGNED THEN <f_matnr> ).
                  ls_pricelist-zzpmatn = COND #( WHEN <f_pmatn> IS ASSIGNED THEN <f_pmatn> ).
                  ls_pricelist-zzkunzf = COND #( WHEN <f_zzkunzf> IS ASSIGNED THEN <f_zzkunzf> ).

                  IF ( s_vkorg[] IS INITIAL OR ls_pricelist-vkorg IN s_vkorg ) AND
                     ( s_matnr[] IS INITIAL OR ls_pricelist-matnr IN s_matnr ) AND
                     ( s_kunnr[] IS INITIAL OR ls_pricelist-kunag IN s_kunnr ) AND
                     ( s_zzpmat[] IS INITIAL OR ls_pricelist-zzpmatn IN s_zzpmat ).

                    APPEND ls_pricelist TO lt_pricelists.
                    CLEAR: ls_pricelist .
                  ENDIF.
                ENDIF.
              ENDLOOP.
            ENDIF.
          ELSE.
            CONTINUE.
          ENDIF.
        ENDLOOP.
        SORT lt_pricelists BY kschl knumh.
        DELETE ADJACENT DUPLICATES FROM lt_pricelists COMPARING knumh.

        "-------------------------------------------------------------
        " 1) Build distinct list of KNUMH from lt_pricelists

        lt_knumh_final = VALUE #(
          FOR wa IN lt_pricelists
          WHERE ( knumh IS NOT INITIAL )
          ( wa-knumh )
        ).
        "-------------------------------------------------------------
        " 2) Single KONP SELECT outside any LOOP (as requested)
        "-------------------------------------------------------------

        IF lt_knumh_final IS NOT INITIAL.
          SELECT knumh
                 kschl
                 loevm_ko
            FROM konp
            INTO TABLE lt_konp_final
            FOR ALL ENTRIES IN lt_knumh_final
            WHERE knumh    = lt_knumh_final-table_line
              AND kschl  IN s_kschl.  "optional, like before
        ENDIF.

        "-------------------------------------------------------------
        " 3) Filter lt_pricelists based on KONP result in memory
        "-------------------------------------------------------------

        SORT lt_konp_final BY knumh loevm_ko.

        LOOP AT lt_pricelists INTO ls_pricelist.
          " Find KONP entry(s) for this KNUMH
          READ TABLE lt_konp_final INTO DATA(ls_konp_final)
               WITH KEY knumh = ls_pricelist-knumh
                        loevm_ko = gc_x
               BINARY SEARCH.

          IF sy-subrc = 0.
            " There is a KONP with loevm_ko = 'X' for this KNUMH -> skip
            CONTINUE.
          ENDIF.

          " Otherwise, keep it
          APPEND ls_pricelist TO lt_pricelists_clean.
          CLEAR ls_pricelist.
        ENDLOOP.

        " Replace original table with filtered one
        lt_pricelists = lt_pricelists_clean.
        CLEAR lt_pricelists_clean.

      ENDIF.
    ENDIF.
  ENDIF.

