  lv_q_from = sy-datum.
  lv_max_days = lc_max_date - sy-datum.
  IF p_day_q > lv_max_days.
    lv_q_to = lc_max_date.
  ELSE.
    lv_q_to = sy-datum + p_day_q.
  ENDIF.

  SELECT a~vbeln,
         a~auart,
         a~vkorg,
         a~angdt,
         a~bnddt,
         a~kunnr,
         b~objnr,
         b~posnr,
         b~matnr,
         t~maktx,
         d~name1,
         j~stat
    FROM vbak AS a
    INNER JOIN vbap AS b ON a~vbeln = b~vbeln
    INNER JOIN mara AS c ON b~matnr = c~matnr
    INNER JOIN kna1 AS d ON a~kunnr = d~kunnr
    LEFT  JOIN makt AS t ON b~matnr = t~matnr AND t~spras = @sy-langu
    INNER JOIN jest AS j ON b~objnr = j~objnr
    INTO TABLE @DATA(lt_vbak)
    WHERE a~vbtyp = @lc_vbtyp_quote
      AND a~vkorg IN @s_vkorg
      AND a~auart IN @s_auart
      AND a~bnddt >= @lv_q_from
      AND a~kunnr IN @s_kunr_q
      AND j~stat  IN @lt_qstat   " WON status
      AND j~inact = @space.       " active only



  LOOP AT lt_vbak INTO DATA(ls_vbak).
    DATA(lv_days2) = ls_vbak-bnddt - sy-datum.

    IF lv_days2 <= p_day_q AND lv_days2 >= 0.
      ls_quote-vbeln     = ls_vbak-vbeln.
      ls_quote-auart     = ls_vbak-auart.
      ls_quote-posnr     = ls_vbak-posnr.
      ls_quote-days_left = lv_days2.
      ls_quote-vkorg     = ls_vbak-vkorg.
      ls_quote-kunnr     = ls_vbak-kunnr.
      ls_quote-name1     = ls_vbak-name1.
      ls_quote-matnr     = ls_vbak-matnr.
      ls_quote-maktx     = ls_vbak-maktx.
      ls_quote-angdt     = ls_vbak-angdt.
      ls_quote-bnddt     = ls_vbak-bnddt.

      APPEND ls_quote TO lt_quotes.
      CLEAR: ls_quote.
    ENDIF.
*    ENDIF.
  ENDLOOP.

  CLEAR: lt_body2, lv_group_key.
  SORT lt_quotes BY days_left vkorg vbeln.

  LOOP AT lt_quotes INTO ls_quote.

    DATA(lv_new_group2) = |{ ls_quote-days_left }_{ ls_quote-vkorg }|.

    IF lv_new_group2 <> lv_group_key.
      lv_group_key = lv_new_group2.

      DATA(lv_unit2) = COND string(
                        WHEN ls_quote-days_left = 1 THEN text-048
                        ELSE text-049 ).

      DATA(lv_header2) = |{ text-057 } { ls_quote-days_left } { lv_unit2 } { text-050 } { ls_quote-vkorg }|.
      APPEND lv_header2  TO lt_body2.
    ENDIF.

    DATA(lv_bnddt_formatted) =
      |{ ls_quote-bnddt+6(2) }.{ ls_quote-bnddt+4(2) }.{ ls_quote-bnddt(4) }|.

    DATA(lv_detail2) = |{ text-058 }{ ls_quote-vbeln } { text-059 }{ ls_quote-posnr }{ text-060 }{ ls_quote-kunnr
     } { text-061 }{ ls_quote-name1 } { text-046 } { ls_quote-matnr } { text-062 } {
      ls_quote-maktx } { text-063 } { lv_bnddt_formatted }|.
    CONDENSE lv_detail2.
    APPEND   lv_detail2 TO lt_body2.
  ENDLOOP.

  IF p_rep = abap_true.
    IF lt_quotes IS INITIAL.
      MESSAGE text-001 TYPE lc_type_i.
      RETURN.
    ENDIF.

    TRY.
        cl_salv_table=>factory(
          IMPORTING
            r_salv_table = lo_alv_q
          CHANGING
            t_table      = lt_quotes ).

        lo_alv_q->get_functions( )->set_all( abap_true ).
        lo_alv_q->get_display_settings( )->set_striped_pattern( abap_true ).
        lo_alv_q->get_display_settings( )->set_list_header( text-031 ).

        DATA(lo_cols) = lo_alv_q->get_columns( ).
        lo_cols->set_optimize( abap_true ).
        TRY.
            lo_cols->get_column( gc_col_auart     )->set_long_text(   text-017 ).
            lo_cols->get_column( gc_col_vbeln     )->set_medium_text( text-018 ).
            lo_cols->get_column( gc_col_posnr     )->set_long_text(   text-019 ).
            lo_cols->get_column( gc_col_vkorg     )->set_long_text(   text-020 ).
            lo_cols->get_column( gc_col_days_left )->set_long_text(   text-021 ).
            lo_cols->get_column( gc_col_kunnr     )->set_long_text(   text-022 ).
            lo_cols->get_column( gc_col_name1     )->set_long_text(   text-023 ).
            lo_cols->get_column( gc_col_matnr     )->set_long_text(   text-024 ).
            lo_cols->get_column( gc_col_maktx     )->set_long_text(   text-025 ).
            lo_cols->get_column( gc_col_angdt     )->set_long_text(   text-016 ).
            lo_cols->get_column( gc_col_bnddt     )->set_long_text(   text-026 ).
          CATCH cx_salv_not_found.
        ENDTRY.
        TRY.
            DATA(lo_col_vkorg2) = lo_cols->get_column( gc_col_vkorg ).
            lo_col_vkorg2->set_visible( if_salv_c_bool_sap=>false ).
          CATCH cx_salv_not_found.
        ENDTRY.

        lo_alv_q->display( ).

      CATCH cx_salv_msg INTO DATA(lx_q).
        MESSAGE lx_q->get_text( ) TYPE lc_type_e.
    ENDTRY.

    RETURN.

  ELSE.

    IF lt_body2 IS INITIAL.
      MESSAGE text-007 TYPE lc_type_i.
      RETURN.
    ENDIF.

*    IF p_email2 IS INITIAL.
*      MESSAGE text-008 TYPE lc_type_e.
*      RETURN.
*    ENDIF.

    DATA(lo_email_sender2) = NEW zcl_email_sender( ).

    " Read Sales Org descriptions for selected VKORGs
    SELECT vkorg,
           vtext
      FROM tvkot
      WHERE spras = @sy-langu
        AND vkorg IN @s_vkorg
      INTO TABLE @lt_tvkot_q.

    SORT lt_tvkot_q BY vkorg.
    DELETE ADJACENT DUPLICATES FROM lt_tvkot_q COMPARING vkorg.

    CLEAR lv_subject_vtext_q.

    LOOP AT lt_tvkot_q INTO ls_row_q.
      DATA(lv_piece_q) = to_upper( ls_row_q-vtext ).
      IF lv_subject_vtext_q IS INITIAL.
        lv_subject_vtext_q = lv_piece_q.
      ELSE.
        CONCATENATE lv_subject_vtext_q lv_piece_q INTO lv_subject_vtext_q SEPARATED BY text-055.
      ENDIF.
    ENDLOOP.
    CONDENSE lv_subject_vtext_q.

    IF lv_subject_vtext_q IS INITIAL.
      lv_subject2 = text-009.
    ELSE.
      lv_subject2 = |{ text-064 } { lv_subject_vtext_q }|.
    ENDIF.

    DATA(lv_ok) = lo_email_sender2->send_email(
                   iv_subject    = lv_subject2
                   it_body       = lt_body2
                   iv_recipients = p_email2
                   iv_cc         = p_em2_cc
                   iv_doc_type   = gc_doc_raw
                   iv_delimiter  = gc_delim_sc ).

    IF lv_ok = abap_true.
      MESSAGE text-010 TYPE lc_type_s.
    ELSE.
      MESSAGE text-011 TYPE lc_type_e.
    ENDIF.

    IF lt_quotes IS INITIAL.
      MESSAGE text-012 TYPE lc_type_i.
      RETURN.
    ENDIF.

  ENDIF.

ENDFORM.
