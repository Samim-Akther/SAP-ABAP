AT SELECTION-SCREEN.


  """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""
  "--------------------------------------------------
  " Validate Sales Org against TVKO
  "--------------------------------------------------
  SELECT vkorg
    FROM tvko
    INTO TABLE @DATA(lt_tvko)
    WHERE vkorg IN @s_vkorg.

  LOOP AT s_vkorg INTO DATA(ls_vkorg).
    IF ls_vkorg-low IS NOT INITIAL.
      READ TABLE lt_tvko WITH KEY vkorg = ls_vkorg-low TRANSPORTING NO FIELDS.
      IF sy-subrc <> 0.
        MESSAGE text-033 TYPE lc_type_e.
      ENDIF.
    ENDIF.

    IF ls_vkorg-high IS NOT INITIAL.
      READ TABLE lt_tvko WITH KEY vkorg = ls_vkorg-high TRANSPORTING NO FIELDS.
      IF sy-subrc <> 0.
        MESSAGE text-033 TYPE lc_type_e.
      ENDIF.
    ENDIF.
  ENDLOOP.


  "--------------------------------------------------
  " Validate Material (Price List) against MARA
  "--------------------------------------------------
  IF r_pl = abap_true AND s_matnr[] IS NOT INITIAL.
    SELECT matnr
      FROM mara
      INTO TABLE @DATA(lt_mara_pl)
      WHERE matnr IN @s_matnr.

    LOOP AT s_matnr INTO DATA(ls_matnr_pl).
      IF ls_matnr_pl-low IS NOT INITIAL.
        READ TABLE lt_mara_pl WITH KEY matnr = ls_matnr_pl-low TRANSPORTING NO FIELDS.
        IF sy-subrc <> 0.
          MESSAGE text-034 TYPE lc_type_e.
        ENDIF.
      ENDIF.

      IF ls_matnr_pl-high IS NOT INITIAL.
        READ TABLE lt_mara_pl WITH KEY matnr = ls_matnr_pl-high TRANSPORTING NO FIELDS.
        IF sy-subrc <> 0.
          MESSAGE text-034 TYPE lc_type_e.
        ENDIF.
      ENDIF.
    ENDLOOP.
  ENDIF.


  "--------------------------------------------------
  " Validate Sold-to (Price List) against KNA1
  "--------------------------------------------------
  IF r_pl = abap_true AND s_kunnr[] IS NOT INITIAL.
    SELECT kunnr
      FROM kna1
      INTO TABLE @DATA(lt_kna1_pl)
      WHERE kunnr IN @s_kunnr.

    LOOP AT s_kunnr INTO DATA(ls_kun_pl).
      IF ls_kun_pl-low IS NOT INITIAL.
        READ TABLE lt_kna1_pl WITH KEY kunnr = ls_kun_pl-low TRANSPORTING NO FIELDS.
        IF sy-subrc <> 0.
          MESSAGE text-035 TYPE lc_type_e.
        ENDIF.
      ENDIF.

      IF ls_kun_pl-high IS NOT INITIAL.
        READ TABLE lt_kna1_pl WITH KEY kunnr = ls_kun_pl-high TRANSPORTING NO FIELDS.
        IF sy-subrc <> 0.
          MESSAGE text-035 TYPE lc_type_e.
        ENDIF.
      ENDIF.
    ENDLOOP.
  ENDIF.

  " Validate ref material (Price List) against mvke

  IF r_pl = abap_true AND s_zzpmat[] IS NOT INITIAL.
    SELECT pmatn
      FROM mvke
      INTO TABLE @DATA(lt_mvke_pl)
      WHERE pmatn IN @s_zzpmat.

    LOOP AT s_zzpmat INTO DATA(ls_mvke_pl).
      IF ls_mvke_pl-low IS NOT INITIAL.
        READ TABLE lt_mvke_pl WITH KEY pmatn = ls_mvke_pl-low TRANSPORTING NO FIELDS.
        IF sy-subrc <> 0.
          MESSAGE text-065 TYPE lc_type_e.
        ENDIF.
      ENDIF.

      IF ls_mvke_pl-high IS NOT INITIAL.
        READ TABLE lt_mvke_pl WITH KEY pmatn = ls_mvke_pl-high TRANSPORTING NO FIELDS.
        IF sy-subrc <> 0.
          MESSAGE text-065 TYPE lc_type_e.
        ENDIF.
      ENDIF.
    ENDLOOP.
  ENDIF.


  "--------------------------------------------------
  " Validate Material (Quotation) against MARA
  "--------------------------------------------------
  IF r_p2 = abap_true AND s_mat_q[] IS NOT INITIAL.
    SELECT matnr
      FROM mara
      INTO TABLE @DATA(lt_mara_q)
      WHERE matnr IN @s_mat_q.

    LOOP AT s_mat_q INTO DATA(ls_mat_q).
      IF ls_mat_q-low IS NOT INITIAL.
        READ TABLE lt_mara_q WITH KEY matnr = ls_mat_q-low TRANSPORTING NO FIELDS.
        IF sy-subrc <> 0.
          MESSAGE text-034 TYPE lc_type_e.
        ENDIF.
      ENDIF.

      IF ls_mat_q-high IS NOT INITIAL.
        READ TABLE lt_mara_q WITH KEY matnr = ls_mat_q-high TRANSPORTING NO FIELDS.
        IF sy-subrc <> 0.
          MESSAGE text-034 TYPE lc_type_e.
        ENDIF.
      ENDIF.
    ENDLOOP.
  ENDIF.

  "--------------------------------------------------
  " Validate Sold-to (Quotation) against KNA1
  "--------------------------------------------------
  IF r_p2 = abap_true AND s_kunr_q[] IS NOT INITIAL.
    SELECT kunnr
      FROM kna1
      INTO TABLE @DATA(lt_kna1_q)
      WHERE kunnr IN @s_kunr_q.

    LOOP AT s_kunr_q INTO DATA(ls_kun_q).
      IF ls_kun_q-low IS NOT INITIAL.
        READ TABLE lt_kna1_q WITH KEY kunnr = ls_kun_q-low TRANSPORTING NO FIELDS.
        IF sy-subrc <> 0.
          MESSAGE text-035 TYPE lc_type_e.
        ENDIF.
      ENDIF.

      IF ls_kun_q-high IS NOT INITIAL.
        READ TABLE lt_kna1_q WITH KEY kunnr = ls_kun_q-high TRANSPORTING NO FIELDS.
        IF sy-subrc <> 0.
          MESSAGE text-035 TYPE lc_type_e.
        ENDIF.
      ENDIF.
    ENDLOOP.
  ENDIF.

  IF sy-ucomm <> gc_onli.
    RETURN.
  ENDIF.

