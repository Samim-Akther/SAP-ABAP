CLASS lcl_pricelist_salv_handler DEFINITION.
  PUBLIC SECTION.
    METHODS:
      constructor
        IMPORTING
          io_alv        TYPE REF TO cl_salv_table
          it_pricelists TYPE ty_t_pricelist,
      on_double_click
                    FOR EVENT double_click OF cl_salv_events_table
        IMPORTING row column.
  PRIVATE SECTION.
    DATA mo_alv        TYPE REF TO cl_salv_table.
    DATA mt_pricelists TYPE ty_t_pricelist.
ENDCLASS.

CLASS lcl_pricelist_salv_handler IMPLEMENTATION.
  METHOD constructor.
    mo_alv        = io_alv.
    mt_pricelists = it_pricelists.
  ENDMETHOD.

  METHOD on_double_click.
    " Only react when user double-clicks on KEY_COMBO column
    IF column <> gc_col_key_combo.
      RETURN.
    ENDIF.
    READ TABLE mt_pricelists INTO ls_pricelist INDEX row.
    IF sy-subrc <> 0.
      RETURN.
    ENDIF.
    DATA(lo_out) = cl_demo_output=>new( ).
    lo_out->begin_section( text-036 ).
    lo_out->write_text( ls_pricelist-key_combo ).
    lo_out->display( ).
  ENDMETHOD.

ENDCLASS.

FORM run_pricelist .
  CLEAR : lv_max_days.
  "Max days allowed from today until 9999-12-31
  lv_max_days = lc_max_date - sy-datum.

  IF p_days > lv_max_days.
    lv_date_to = lc_max_date.
  ELSE.
    lv_date_to = sy-datum + p_days.
  ENDIF.


  CLEAR lt_kschl.
  LOOP AT s_kschl ASSIGNING FIELD-SYMBOL(<s>).
    APPEND VALUE #( kschl = <s>-low ) TO lt_kschl.
  ENDLOOP.

  IF lt_kschl IS NOT INITIAL.
    SELECT kvewe,
           kappl,
           kschl,
           kozgf FROM t685 INTO TABLE @DATA(lt_t685)
           FOR ALL ENTRIES IN @lt_kschl
           WHERE kschl = @lt_kschl-kschl.

    IF sy-subrc = 0 AND lt_t685 IS NOT INITIAL.

      SELECT kvewe,
             kappl,
             kozgf,
             kolnr,
             kotabnr FROM t682i INTO TABLE @DATA(lt_t682i)
             FOR ALL ENTRIES IN @lt_t685
             WHERE kvewe = @lt_t685-kvewe AND
                   kappl = @lt_t685-kappl AND
                   kozgf = @lt_t685-kozgf.

      IF sy-subrc = 0 AND lt_t682i IS NOT INITIAL.

        "Collect all GSTRU values from LT_T682I (each is KVEWE+KOTABNR)
        LOOP AT lt_t682i ASSIGNING FIELD-SYMBOL(<fs_t682i_cache>).
          DATA(lv_gstru) = |{ <fs_t682i_cache>-kvewe }{ <fs_t682i_cache>-kotabnr }|.
          APPEND VALUE #( gstru = lv_gstru ) TO lt_gstru.
        ENDLOOP.

        SORT lt_gstru BY gstru.
        DELETE ADJACENT DUPLICATES FROM lt_gstru COMPARING gstru.
        IF lt_gstru IS NOT INITIAL.
          SELECT spras,
                 gstru,
                 gstxt
            FROM tmc1t
            INTO TABLE @lt_tmc1t
            FOR ALL ENTRIES IN @lt_gstru
            WHERE spras = @sy-langu
              AND gstru = @lt_gstru-gstru.
        ENDIF.

        LOOP AT lt_t682i ASSIGNING FIELD-SYMBOL(<fs_t682i>).
          DATA(lv_tabname) = |{ <fs_t682i>-kvewe }{ <fs_t682i>-kotabnr }|.
          CREATE DATA lo_data TYPE TABLE OF (lv_tabname).
          ASSIGN lo_data->* TO <dyn_table>.

          CLEAR: lt_dfies, lv_has_datbi, lv_tabname2.
          lv_tabname2  = lv_tabname.
          CALL FUNCTION 'DDIF_FIELDINFO_GET'
            EXPORTING
              tabname        = lv_tabname2
              langu          = sy-langu
              all_types      = gc_x
            TABLES
              dfies_tab      = lt_dfies
            EXCEPTIONS
              not_found      = 1
              internal_error = 2
              OTHERS         = 3.

          IF sy-subrc = 0.
            READ TABLE lt_dfies WITH KEY fieldname = gc_fld_datbi
                 TRANSPORTING NO FIELDS.
            IF sy-subrc = 0.
              lv_has_datbi = abap_true.
            ENDIF.
          ENDIF.
          IF lv_has_datbi = abap_true.
            SELECT * FROM (lv_tabname)
              INTO TABLE @<dyn_table>
              WHERE kschl IN @s_kschl
              AND datbi >= @sy-datum
              AND datbi <= @lv_date_to.
            IF sy-subrc <> 0 OR <dyn_table> IS INITIAL.
              CONTINUE.
            ENDIF.

            IF sy-subrc = 0.

              LOOP AT <dyn_table> ASSIGNING <dyn_line>.

                DATA(lv_tab_desc) = VALUE string( ).

                READ TABLE lt_tmc1t INTO DATA(ls_tmc1t)
                     WITH KEY spras = sy-langu
                              gstru = lv_tabname
                     BINARY SEARCH.

                IF sy-subrc = 0.
                  lv_tab_desc = ls_tmc1t-gstxt.
                ENDIF.

                ASSIGN COMPONENT gc_fld_kschl   OF STRUCTURE <dyn_line> TO FIELD-SYMBOL(<f_kschl>).
                IF sy-subrc <> 0.
                  UNASSIGN <f_kschl>.
                ENDIF.

                ASSIGN COMPONENT gc_fld_datbi   OF STRUCTURE <dyn_line> TO FIELD-SYMBOL(<f_datbi>).
                IF sy-subrc <> 0 OR <f_datbi> IS INITIAL.
                  CONTINUE.
                ENDIF.

                DATA(lv_days) = <f_datbi> - sy-datum.
                "Only records expiring within P_DAYS from today
                IF lv_days <= p_days AND lv_days > 0.
                  ASSIGN COMPONENT gc_fld_knumh   OF STRUCTURE <dyn_line> TO FIELD-SYMBOL(<f_knumh>).
                  IF sy-subrc <> 0.
                    UNASSIGN <f_knumh>.
                  ENDIF.

                  ASSIGN COMPONENT gc_fld_kunnr OF STRUCTURE <dyn_line> TO FIELD-SYMBOL(<f_kunnr>).
                  IF sy-subrc <> 0.
                    UNASSIGN <f_kunnr>.
                  ENDIF.

                  ASSIGN COMPONENT gc_fld_matnr OF STRUCTURE <dyn_line> TO FIELD-SYMBOL(<f_matnr>).
                  IF sy-subrc <> 0.
                    UNASSIGN <f_matnr>.
                  ENDIF.

                  ASSIGN COMPONENT gc_fld_zzpmatn OF STRUCTURE <dyn_line> TO FIELD-SYMBOL(<f_pmatn>).
                  IF sy-subrc <> 0.
                    UNASSIGN <f_pmatn>.
                  ENDIF.

                  ASSIGN COMPONENT gc_fld_vkorg  OF STRUCTURE <dyn_line> TO FIELD-SYMBOL(<f_vkorg>).
                  IF sy-subrc <> 0.
                    UNASSIGN <f_vkorg>.
                  ENDIF.

                  ASSIGN COMPONENT gc_fld_vtweg  OF STRUCTURE <dyn_line> TO FIELD-SYMBOL(<f_vtweg>).
                  IF sy-subrc <> 0.
                    UNASSIGN <f_vtweg>.
                  ENDIF.

                  ASSIGN COMPONENT gc_fld_spart  OF STRUCTURE <dyn_line> TO FIELD-SYMBOL(<f_spart>).
                  IF sy-subrc <> 0.
                    UNASSIGN <f_spart>.
                  ENDIF.

                  ASSIGN COMPONENT gc_fld_kunag OF STRUCTURE <dyn_line> TO FIELD-SYMBOL(<f_kunag>).
                  IF sy-subrc <> 0.
                    UNASSIGN <f_kunag>.
                  ENDIF.

                  ASSIGN COMPONENT gc_fld_kunwe  OF STRUCTURE <dyn_line> TO FIELD-SYMBOL(<f_kunwe>).
                  IF sy-subrc <> 0.
                    UNASSIGN <f_kunwe>.
                  ENDIF.

                  ASSIGN COMPONENT gc_fld_zzkunzf OF STRUCTURE <dyn_line> TO FIELD-SYMBOL(<f_zzkunzf>).
                  IF sy-subrc <> 0.
                    UNASSIGN <f_zzkunzf>.
                  ENDIF.

                  ASSIGN COMPONENT gc_fld_inco1  OF STRUCTURE <dyn_line> TO FIELD-SYMBOL(<f_inco1>).
                  IF sy-subrc <> 0.
                    UNASSIGN <f_inco1>.
                  ENDIF.

                  ASSIGN COMPONENT gc_fld_vsbed  OF STRUCTURE <dyn_line> TO FIELD-SYMBOL(<f_vsbed>).
                  IF sy-subrc <> 0.
                    UNASSIGN <f_vsbed>.
                  ENDIF.

                  DATA(lv_combo) = ``.

                  IF <f_vkorg> IS ASSIGNED AND <f_vkorg> IS NOT INITIAL.
                    lv_combo = lv_combo && | { text-038 } { <f_vkorg> }|.
                  ENDIF.

                  IF <f_vtweg> IS ASSIGNED AND <f_vtweg> IS NOT INITIAL.
                    lv_combo = lv_combo && | { text-039 } { <f_vtweg> }|.
