*&---------------------------------------------------------------------*
*&      Form  DATES_CALC
*&---------------------------------------------------------------------*
FORM dates_calc.

  DATA: lv_datum     TYPE sy-datum,
        lv_field(20),
        lv_count     TYPE i,
        lv_fabkl     TYPE t001w-fabkl.

  FIELD-SYMBOLS: <field> TYPE any.

  IF p_choose = '2'.
    SELECT SINGLE fabkl
            FROM  t001w INTO lv_fabkl
            WHERE werks = p_werks.
  ENDIF.

  lv_count = 1.
  lv_datum = gv_start.
  DO gv_buckets TIMES.
    lv_field = lv_count.
    SHIFT lv_field LEFT DELETING LEADING space.
    CONCATENATE 'GS_DATUM-D' lv_field INTO lv_field.
    ASSIGN (lv_field) TO <field>.
    CASE p_type.
      WHEN 'M'.
        CASE p_choose.
          WHEN '1'.
            <field> = lv_datum.
            lv_datum = lv_datum + 31.
            lv_datum+6(2) = '01'.
          WHEN '2'.
            CALL FUNCTION 'FKK_LAST_DAY_OF_MONTH'
              EXPORTING
                day_in            = lv_datum
              IMPORTING
                last_day_of_month = <field>
              EXCEPTIONS
                day_in_no_date    = 1
                OTHERS            = 2.
            lv_datum = <field> + 1.
            CALL FUNCTION 'BKK_GET_PRIOR_WORKDAY'
              EXPORTING
                i_date         = <field>
                i_calendar1    = lv_fabkl
              IMPORTING
                e_workday      = <field>
              EXCEPTIONS
                calendar_error = 1
                OTHERS         = 2.
        ENDCASE.
      WHEN 'W'.
        CASE p_choose.
          WHEN '1'.
            <field> = lv_datum.
          WHEN '2'.
            CALL FUNCTION 'GET_WEEK_INFO_BASED_ON_DATE'
              EXPORTING
                date   = lv_datum
              IMPORTING
                sunday = <field>.
            CALL FUNCTION 'BKK_GET_PRIOR_WORKDAY'
              EXPORTING
                i_date         = <field>
                i_calendar1    = lv_fabkl
              IMPORTING
                e_workday      = <field>
              EXCEPTIONS
                calendar_error = 1
                OTHERS         = 2.
        ENDCASE.
        lv_datum = lv_datum + 7.
      WHEN 'D'.
        <field> = lv_datum.
        lv_datum = lv_datum + 1.
    ENDCASE.
    lv_count = lv_count + 1.
  ENDDO.

ENDFORM.

