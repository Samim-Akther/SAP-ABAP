"boc by samim cr-4201
*&---------------------------------------------------------------------*
*&      Form  READ_FILE_XLSX
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM read_file_xlsx .
  CLEAR: ls_error, lt_error.
  "----------------------------------------------------
  " 1) Upload XLSX as binary
  "----------------------------------------------------
  CALL FUNCTION 'GUI_UPLOAD'
    EXPORTING
      filename   = p_file
      filetype   = 'BIN'
    IMPORTING
      filelength = lv_filelength
    TABLES
      data_tab   = lt_records
    EXCEPTIONS
      OTHERS     = 1.

  IF sy-subrc = 0.
    "----------------------------------------------------
    " 2) Convert binary to XSTRING
    "----------------------------------------------------
    CALL FUNCTION 'SCMS_BINARY_TO_XSTRING'
      EXPORTING
        input_length = lv_filelength
      IMPORTING
        buffer       = lv_xstring
      TABLES
        binary_tab   = lt_records
      EXCEPTIONS
        OTHERS       = 1.

    IF lv_xstring IS NOT INITIAL.

      "----------------------------------------------------
      " 3) Load XLSX
      "----------------------------------------------------
      TRY.
          lo_excel_ref = NEW cl_fdt_xl_spreadsheet(
                           document_name = p_file
                           xdocument     = lv_xstring ).
        CATCH cx_fdt_excel_core INTO DATA(lx).
          MESSAGE lx->get_text( ) TYPE lc_update.
          RETURN.
      ENDTRY.

      "----------------------------------------------------
      " 4) Get first worksheet
      "----------------------------------------------------
      lo_excel_ref->if_fdt_doc_spreadsheet~get_worksheet_names(
        IMPORTING worksheet_names = lt_sheets ).

      READ TABLE lt_sheets INTO lv_sheet INDEX 1.
      IF sy-subrc =  0.
        "----------------------------------------------------
        " 5) Read worksheet content into dynamic internal table
        "----------------------------------------------------
        DATA(lo_data_ref) =
            lo_excel_ref->if_fdt_doc_spreadsheet~get_itab_from_worksheet( lv_sheet ).

        ASSIGN lo_data_ref->* TO <gt_data>.
        IF <gt_data> IS NOT ASSIGNED OR <gt_data> IS INITIAL.
          MESSAGE i380.
          RETURN.
        ENDIF.

        "--- Remove header row (same as i_line_header = abap_true)
        DELETE <gt_data> INDEX 1.

        "----------------------------------------------------
        " 6) Map dynamic table into your typed table gt_file_xlsx
        "----------------------------------------------------
        CLEAR gt_file_xlsx.

        "Determine number of fields in your structure
        DATA(ls_dummy) = VALUE lt_file_xlsx( ).
        DATA(lo_struct) = CAST cl_abap_structdescr(
                             cl_abap_typedescr=>describe_by_data( ls_dummy ) ).
        DATA(lv_cols) = lines( lo_struct->components ).

        LOOP AT <gt_data> ASSIGNING <ls_row>.
          APPEND INITIAL LINE TO gt_file_xlsx ASSIGNING FIELD-SYMBOL(<ls_out>).

          DO lv_cols TIMES.
            ASSIGN COMPONENT sy-index OF STRUCTURE <ls_row> TO <fs_src>.
            IF <fs_src> IS NOT ASSIGNED.
              EXIT.
            ENDIF.

            ASSIGN COMPONENT sy-index OF STRUCTURE <ls_out> TO <fs_dst>.
            IF <fs_dst> IS ASSIGNED.
              <fs_dst> = <fs_src>.
            ENDIF.

            UNASSIGN <fs_src>.
            UNASSIGN <fs_dst>.
          ENDDO.
        ENDLOOP.
      ENDIF.
    ENDIF.
  ENDIF.
  IF gt_file_xlsx IS NOT INITIAL.
    LOOP AT gt_file_xlsx INTO DATA(ls_data).
      APPEND VALUE #( sign = lc_sign option = lc_option low = |{ ls_data-incomfld ALPHA = IN }| ) TO lr_matnr.
    ENDLOOP.
    SORT: gt_file_xlsx BY incomfld.
    IF p_kdmat = abap_true.
      SELECT vkorg,
             vtweg,
             kunnr,
             matnr,
             kdmat,
             meins
            FROM knmt
            INTO TABLE @DATA(lt_knmt)
            FOR ALL ENTRIES IN @gt_file_xlsx
             WHERE kdmat = @gt_file_xlsx-incomfld.
    ELSE.
      IF lr_matnr IS NOT INITIAL.
        SELECT matnr FROM mara INTO TABLE @DATA(lt_mara)
          WHERE matnr IN @lr_matnr.
      ENDIF.
    ENDIF.
    SORT: gt_file_xlsx BY incomfld,
          lt_knmt      BY kdmat matnr,
          lt_mara      BY matnr.

    LOOP AT lt_knmt INTO DATA(ls_knmt).

      " Check if Excel has this kdmat
      READ TABLE gt_file_xlsx INTO DATA(gs_file_xlsx)
           WITH KEY incomfld = ls_knmt-kdmat
           BINARY SEARCH.

      IF sy-subrc = 0.

        " First time we see this kdmat
        IF lv_prev_kdmat IS INITIAL OR lv_prev_kdmat <> ls_knmt-kdmat.
          lv_prev_kdmat = ls_knmt-kdmat.
          lv_prev_matnr = ls_knmt-matnr.

        ELSE.
          " Same kdmat again → check matnr consistency
          IF lv_prev_matnr <> ls_knmt-matnr.
*            lv_error = abap_true.
            APPEND lv_prev_kdmat TO lt_error.
          ENDIF.
        ENDIF.
      ENDIF.
    ENDLOOP.

    CONCATENATE LINES OF lt_error INTO ls_error SEPARATED BY ', '.

*    IF lv_error = abap_true.
    IF ls_error IS NOT INITIAL.
      MESSAGE i517 WITH ls_error DISPLAY LIKE lc_mode.
      EXIT.
    ELSE.
      CLEAR : gs_file_xlsx,ls_knmt.
      LOOP AT gt_file_xlsx INTO gs_file_xlsx.

        READ TABLE lt_knmt INTO ls_knmt
             WITH KEY kdmat = gs_file_xlsx-incomfld
             BINARY SEARCH.
        IF sy-subrc = 0.
          CLEAR gs_alv.
          gs_alv = CORRESPONDING #( ls_knmt ).
          gs_alv = CORRESPONDING #( BASE ( gs_alv ) gs_file_xlsx ).
          APPEND gs_alv TO gt_file_ck.
          CLEAR: gs_alv.
        ELSE.
          DATA(lv_matnr) = CONV matnr( gs_file_xlsx-incomfld ).
          lv_matnr = |{ lv_matnr ALPHA = IN }|.

          READ TABLE lt_mara INTO DATA(ls_mara)
           WITH KEY matnr =  lv_matnr
           BINARY SEARCH.
          IF sy-subrc = 0.
            CLEAR gs_alv.
            gs_alv = CORRESPONDING #( ls_mara ).
            gs_alv = CORRESPONDING #( BASE ( gs_alv ) gs_file_xlsx ).
            APPEND gs_alv TO gt_file_ck.
            CLEAR:gs_alv,lv_matnr.
          ENDIF.
        ENDIF.
      ENDLOOP.
      CLEAR : gs_file_xlsx,ls_knmt.
    ENDIF.

  ENDIF.
  SORT gt_file_ck BY matnr.
  IF gt_file_ck[] IS NOT INITIAL.
    LOOP AT gt_file_ck INTO DATA(ls_ck).
      CLEAR gt_file.
      gt_file = CORRESPONDING #( ls_ck ).
      APPEND gt_file.
      CLEAR:ls_ck.
    ENDLOOP.
  ENDIF.
ENDFORM.
