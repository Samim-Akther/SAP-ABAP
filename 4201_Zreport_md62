*&      Form  MD62_DELETE
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM md62_delete .
  SELECT matnr,
   werks,
   bedae,
   versb,
   pbdnr,bdzei FROM pbim INTO TABLE @DATA(lt_pbim) FOR ALL ENTRIES IN
                     @gt_file_ck WHERE matnr = @gt_file_ck-matnr AND
                     werks = @p_werks AND
                     versb = @p_versb AND
                     pbdnr = @p_pbdnr AND
                     loevr = @space.
  IF sy-subrc = 0.
    SORT lt_pbim BY matnr.
  ENDIF.
  LOOP AT gt_file INTO DATA(ls_file).

    IF ls_file-q1  IS INITIAL
    AND ls_file-q2  IS INITIAL
    AND ls_file-q3  IS INITIAL
    AND ls_file-q4  IS INITIAL
    AND ls_file-q5  IS INITIAL
    AND ls_file-q6  IS INITIAL
    AND ls_file-q7  IS INITIAL
    AND ls_file-q8  IS INITIAL
    AND ls_file-q9  IS INITIAL
    AND ls_file-q10 IS INITIAL
    AND ls_file-q11 IS INITIAL
    AND ls_file-q12 IS INITIAL.

      APPEND ls_file TO gt_file_delete.
      CLEAR ls_file.
    ELSE.
      READ TABLE lt_pbim ASSIGNING FIELD-SYMBOL(<fs_pbim>) WITH KEY matnr = ls_file-matnr
                                                                    werks = p_werks
                                                                    versb = p_versb
                                                                    pbdnr = p_pbdnr  BINARY SEARCH.
      IF sy-subrc = 0.
        APPEND ls_file TO gt_file_update.
        CLEAR ls_file.
      ELSE.
        APPEND ls_file TO gt_file_create.
        CLEAR ls_file.
      ENDIF.
    ENDIF.
  ENDLOOP.

  LOOP AT gt_file_delete ASSIGNING FIELD-SYMBOL(<fs_file>).
    READ TABLE lt_pbim ASSIGNING FIELD-SYMBOL(<fs_pbim2>) WITH KEY
    matnr = <fs_file>-matnr
    werks = p_werks
    versb = p_versb
    pbdnr = p_pbdnr
     BINARY SEARCH.
    IF sy-subrc = 0.

      gs_cm60r-trtyp = lc_v.
      gs_cm60r-commi = lc_x.
      gs_cm60r-upddc = lc_x.
      gs_cm60r-delkz = lc_x.
      gs_cm60r-status = lc_v.


      gs_pbpt-matnr = <fs_pbim2>-matnr.
      gs_pbpt-werks = p_werks.
      gs_pbpt-bedae = <fs_pbim2>-bedae.
      gs_pbpt-versb = <fs_pbim2>-versb.
      gs_pbpt-updkz = lc_d.


      APPEND gs_pbpt TO gt_pbpt.
      CLEAR gs_pbpt.

      CALL FUNCTION 'REQUIREMENTS_MAINTAIN'
        EXPORTING
          ecm60r = gs_cm60r
          ecm60a = gs_cm60a
        TABLES
          epbpt  = gt_pbpt
          iproto = gt_pbmsg
        EXCEPTIONS
          error  = 1
          OTHERS = 2.
      IF sy-subrc <> 0.
* Implement suitable error handling here
      ENDIF.
    ENDIF.
  ENDLOOP.
ENDFORM.
