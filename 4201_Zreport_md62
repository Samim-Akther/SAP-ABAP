*&---------------------------------------------------------------------*
FORM field_catalog.

  DATA: lv_head(10),
        lv_index     TYPE sy-index,
        lv_field(20).

  FIELD-SYMBOLS: <date> TYPE d.

  PERFORM fill_fieldcat USING 'GT_ALV' 'SEM'   ' ' text-a01.
  PERFORM fill_fieldcat USING 'GT_ALV' 'MATNR' 'X' text-a02.
  PERFORM fill_fieldcat USING 'GT_ALV' 'MEINS' ' ' text-a03.
  DO gv_buckets TIMES.
    lv_index = sy-index.
    ASSIGN COMPONENT lv_index OF STRUCTURE gs_datum TO <date>.
    WRITE <date> TO lv_head.
    lv_field = lv_index.
    SHIFT lv_field LEFT DELETING LEADING space.
    CONCATENATE 'Q' lv_field INTO lv_field.
    PERFORM fill_fieldcat USING 'GT_ALV' lv_field ' ' lv_head.
  ENDDO.
  PERFORM fill_fieldcat USING 'GT_ALV' 'MESS'  ' ' text-a04.

ENDFORM.

