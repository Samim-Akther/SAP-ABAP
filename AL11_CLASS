class ZCL_DATA_EXPORT_UTILITY definition
  public
  final
  create public .

public section.

  types:
    BEGIN OF ty_field_text,
             col_name   TYPE lvc_fname,
             col_text_s TYPE scrtext_s,
             col_text_m TYPE scrtext_m,
             col_text_l TYPE scrtext_l,
           END OF ty_field_text .
  types:
    tt_field_text TYPE STANDARD TABLE OF ty_field_text WITH EMPTY KEY .

  methods DISPLAY_ALV
    importing
      value(IR_DATA) type ref to DATA
      !IT_FIELD_NAMES type TT_FIELD_TEXT
    returning
      value(RV_MESSAGE) type STRING .
  methods DOWNLOAD_TO_LOCAL
    importing
      value(IR_DATA) type ref to DATA
      value(IV_FORMAT) type STRING
      value(IV_FILENAME) type STRING
      !IT_FIELD_NAMES type TT_FIELD_TEXT
    returning
      value(RV_MESSAGE) type STRING .
  methods WRITE_TO_AL11
    importing
      value(IR_DATA) type ref to DATA
      value(IV_FORMAT) type STRING
      value(IV_FILENAME) type STRING
      value(IV_DIRECTORY) type STRING
      !IT_FIELD_NAMES type TT_FIELD_TEXT optional
      !IV_DELIMITER type CHAR1 optional
    returning
      value(RV_MESSAGE) type STRING .
  methods CONVERT_TO_FORMAT
    importing
      value(IR_DATA) type ref to DATA
      value(IV_FORMAT) type STRING
      !IT_FIELD_NAMES type TT_FIELD_TEXT
    returning
      value(RV_CONTENT) type STRING .
  methods SET_DATA
    importing
      value(IR_DATA) type ref to DATA .
  methods GET_DATA
    returning
      value(RR_DATA) type ref to DATA .
  methods SET_COLUMN_TEXT
    importing
      value(COLUMN_NAME) type LVC_FNAME
      !COL_TEXT_L type SCRTEXT_L
      !COL_TEXT_M type SCRTEXT_M
      !COL_TEXT_S type SCRTEXT_S
    returning
      value(RT_FIELD_TEXT) type TT_FIELD_TEXT .
protected section.
private section.

  class-data GR_DATA type ref to DATA .
  data MV_DELIMITER type CHAR1 .
ENDCLASS.



CLASS ZCL_DATA_EXPORT_UTILITY IMPLEMENTATION.


* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Public Method ZCL_DATA_EXPORT_UTILITY->CONVERT_TO_FORMAT
* +-------------------------------------------------------------------------------------------------+
* | [--->] IR_DATA                        TYPE REF TO DATA
* | [--->] IV_FORMAT                      TYPE        STRING
* | [--->] IT_FIELD_NAMES                 TYPE        TT_FIELD_TEXT
* | [<-()] RV_CONTENT                     TYPE        STRING
* +--------------------------------------------------------------------------------------</SIGNATURE>
METHOD convert_to_format.

  DATA: lv_sep TYPE c.

  FIELD-SYMBOLS: <lt_table> TYPE STANDARD TABLE,
                 <ls_row>   TYPE any,
                 <lv_field> TYPE any.

  ASSIGN ir_data->* TO <lt_table>.
  IF sy-subrc <> 0.
    rv_content = 'Error: Cannot assign dynamic data'.
    RETURN.
  ENDIF.

  IF iv_format = 'CSV'.
    IF me->mv_delimiter IS NOT INITIAL.
     lv_sep = me->mv_delimiter.
    ELSE.
      lv_sep = ','.
    ENDIF.
  ELSEIF iv_format = 'XLS'.
    lv_sep = cl_abap_char_utilities=>horizontal_tab.
  ENDIF.

  IF iv_format = 'CSV' OR iv_format = 'XLS'.
    LOOP AT it_field_names INTO DATA(ls_field).

      IF rv_content IS INITIAL.
        rv_content = ls_field-col_text_l.
      ELSE.
        CONCATENATE rv_content ls_field-col_text_l INTO rv_content SEPARATED BY lv_sep.
      ENDIF.
    ENDLOOP.
    "CONCATENATE rv_content lv_header INTO rv_content SEPARATED BY cl_abap_char_utilities=>newline.
  ENDIF.

  LOOP AT <lt_table> ASSIGNING <ls_row>.
    " Cast to CL_ABAP_STRUCTDESCR to access GET_COMPONENTS
    DATA(lo_structdesc) = CAST cl_abap_structdescr(
      cl_abap_typedescr=>describe_by_data( <ls_row> )
    ).
    DATA(lt_components) = lo_structdesc->get_components( ).

    CASE iv_format.
      WHEN 'CSV'.
        DATA lv_line_csv TYPE string.
        CLEAR lv_line_csv.
        LOOP AT lt_components INTO DATA(ls_comp_csv).
          ASSIGN COMPONENT ls_comp_csv-name OF STRUCTURE <ls_row> TO <lv_field>.
          IF sy-subrc = 0.
            DATA lv_value_csv TYPE c LENGTH 255.
            WRITE <lv_field> TO lv_value_csv LEFT-JUSTIFIED.
            IF lv_line_csv IS INITIAL.
              lv_line_csv = lv_value_csv.
            ELSE.
              CONCATENATE lv_line_csv lv_value_csv INTO lv_line_csv SEPARATED BY lv_sep.
            ENDIF.
          ENDIF.
        ENDLOOP.
        IF rv_content IS INITIAL.
          rv_content = lv_line_csv.
        ELSE.
          CONCATENATE rv_content lv_line_csv INTO rv_content SEPARATED BY cl_abap_char_utilities=>newline.
        ENDIF.

      WHEN 'XML'.
        CONCATENATE rv_content '  <DocumentHeader>' cl_abap_char_utilities=>newline INTO rv_content.
        LOOP AT lt_components INTO DATA(ls_comp_xml).
          ASSIGN COMPONENT ls_comp_xml-name OF STRUCTURE <ls_row> TO <lv_field>.
          IF sy-subrc = 0.
            DATA(lv_tabix) = sy-tabix.
            DATA lv_value_xml TYPE c LENGTH 255.
            WRITE <lv_field> TO lv_value_xml.
            DATA lv_tag_line TYPE string.

            READ TABLE it_field_names INTO DATA(lw_fld) WITH KEY col_name = ls_comp_xml-name.
            IF sy-subrc IS INITIAL.
              ls_comp_xml-name = lw_fld-col_text_l.
            ENDIF.
            CONCATENATE '<' ls_comp_xml-name '>' lv_value_xml '</' ls_comp_xml-name '>' INTO lv_tag_line.
            CONCATENATE rv_content lv_tag_line INTO rv_content SEPARATED BY cl_abap_char_utilities=>newline.
            IF lv_tabix = 2.
              CONCATENATE rv_content '  </DocumentHeader>' cl_abap_char_utilities=>newline INTO rv_content.
              CONCATENATE rv_content '  <Message>' cl_abap_char_utilities=>newline INTO rv_content.
              CONCATENATE rv_content '  <PalletMovement>' cl_abap_char_utilities=>newline INTO rv_content.
            ENDIF.
          ENDIF.
        ENDLOOP.
        CONCATENATE rv_content '  </PalletMovement>' cl_abap_char_utilities=>newline INTO rv_content.
        CONCATENATE rv_content '  </Message>' cl_abap_char_utilities=>newline INTO rv_content.

      WHEN 'XLS'.
        DATA lv_line_xls TYPE string.
        CLEAR lv_line_xls.
        LOOP AT lt_components INTO DATA(ls_comp_xls).
          ASSIGN COMPONENT ls_comp_xls-name OF STRUCTURE <ls_row> TO <lv_field>.
          IF sy-subrc = 0.
            DATA lv_value_xls TYPE c LENGTH 255.
            WRITE <lv_field> TO lv_value_xls.
            IF lv_line_xls IS INITIAL.
              lv_line_xls = lv_value_xls.
            ELSE.
              CONCATENATE lv_line_xls lv_value_xls INTO lv_line_xls SEPARATED BY cl_abap_char_utilities=>horizontal_tab.
            ENDIF.
          ENDIF.
        ENDLOOP.
        IF rv_content IS INITIAL.
          rv_content = lv_line_csv.
        ELSE.
          CONCATENATE rv_content lv_line_xls INTO rv_content SEPARATED BY cl_abap_char_utilities=>newline.
        ENDIF.
    ENDCASE.
  ENDLOOP.

  " Wrap XML if needed
  IF iv_format = 'XML'.
    rv_content = |<?xml version="1.0" encoding="UTF-8"?>{ cl_abap_char_utilities=>newline }<Document>{ cl_abap_char_utilities=>newline }| &&
                 rv_content &&
                 |</Document>|.
  ENDIF.
ENDMETHOD.


* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Public Method ZCL_DATA_EXPORT_UTILITY->DISPLAY_ALV
* +-------------------------------------------------------------------------------------------------+
* | [--->] IR_DATA                        TYPE REF TO DATA
* | [--->] IT_FIELD_NAMES                 TYPE        TT_FIELD_TEXT
* | [<-()] RV_MESSAGE                     TYPE        STRING
* +--------------------------------------------------------------------------------------</SIGNATURE>
METHOD display_alv.

  FIELD-SYMBOLS: <lt_table> TYPE STANDARD TABLE.
  DATA: lo_table    TYPE REF TO cl_salv_table,
        lo_columns  TYPE REF TO cl_salv_columns_table,
        lo_column   TYPE REF TO cl_salv_column,
        lv_index    TYPE lvc_fname,
        lv_col_text TYPE scrtext_m.

  ASSIGN ir_data->* TO <lt_table>.
  IF sy-subrc <> 0.
    rv_message = 'Error: Failed to assign dynamic data.'.
    RETURN.
  ENDIF.

  TRY.
      cl_salv_table=>factory(
        IMPORTING r_salv_table = lo_table
        CHANGING  t_table      = <lt_table> ).

      lo_table->get_functions( )->set_all( abap_true ).
      lo_table->get_display_settings( )->set_striped_pattern( abap_true ).
      lo_table->get_columns( )->set_optimize( abap_true ).

      lo_columns = lo_table->get_columns( ).

      LOOP AT it_field_names INTO DATA(lw_fname).
        TRY.
            lo_column = lo_columns->get_column( lw_fname-col_name ).
            lo_column->set_long_text( lw_fname-col_text_l ).
            lo_column->set_medium_text( lw_fname-col_text_m ).
            lo_column->set_short_text( lw_fname-col_text_s ).
          CATCH cx_salv_not_found.
        ENDTRY.
      ENDLOOP.

      lo_table->display( ).
      rv_message = 'ALV displayed successfully.'.

    CATCH cx_salv_msg INTO DATA(lx_msg).
      rv_message = lx_msg->get_text( ).
  ENDTRY.
ENDMETHOD.

