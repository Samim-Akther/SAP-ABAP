* | Instance Public Method ZCL_DATA_EXPORT_UTILITY->GET_DATA
* +-------------------------------------------------------------------------------------------------+
* | [<-()] RR_DATA                        TYPE REF TO DATA
* +--------------------------------------------------------------------------------------</SIGNATURE>
  METHOD get_data.
    rr_data = gr_data.
  ENDMETHOD.


* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Public Method ZCL_DATA_EXPORT_UTILITY->SET_COLUMN_TEXT
* +-------------------------------------------------------------------------------------------------+
* | [--->] COLUMN_NAME                    TYPE        LVC_FNAME
* | [--->] COL_TEXT_L                     TYPE        SCRTEXT_L
* | [--->] COL_TEXT_M                     TYPE        SCRTEXT_M
* | [--->] COL_TEXT_S                     TYPE        SCRTEXT_S
* | [<-()] RT_FIELD_TEXT                  TYPE        TT_FIELD_TEXT
* +--------------------------------------------------------------------------------------</SIGNATURE>
  METHOD set_column_text.
    DATA: lw_field_text TYPE ty_field_text.

    lw_field_text-col_name =   column_name.
    lw_field_text-col_text_s = col_text_s.
    lw_field_text-col_text_m = col_text_m.
    lw_field_text-col_text_l = col_text_l.
    APPEND lw_field_text TO rt_field_text.
    CLEAR: lw_field_text.
  ENDMETHOD.


* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Public Method ZCL_DATA_EXPORT_UTILITY->SET_DATA
* +-------------------------------------------------------------------------------------------------+
* | [--->] IR_DATA                        TYPE REF TO DATA
* +--------------------------------------------------------------------------------------</SIGNATURE>
  METHOD set_data.
    gr_data = ir_data.
  ENDMETHOD.


* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Public Method ZCL_DATA_EXPORT_UTILITY->WRITE_TO_AL11
* +-------------------------------------------------------------------------------------------------+
* | [--->] IR_DATA                        TYPE REF TO DATA
* | [--->] IV_FORMAT                      TYPE        STRING
* | [--->] IV_FILENAME                    TYPE        STRING
* | [--->] IV_DIRECTORY                   TYPE        STRING
* | [--->] IT_FIELD_NAMES                 TYPE        TT_FIELD_TEXT(optional)
* | [--->] IV_DELIMITER                   TYPE        CHAR1(optional)
* | [<-()] RV_MESSAGE                     TYPE        STRING
* +--------------------------------------------------------------------------------------</SIGNATURE>
  METHOD write_to_al11.

    FIELD-SYMBOLS: <lt_table> TYPE STANDARD TABLE.
    DATA: lv_full_path TYPE string,
          lv_content   TYPE string,
          lt_lines     TYPE STANDARD TABLE OF string,
          lv_line      TYPE string.

    me->mv_delimiter = iv_delimiter.

    ASSIGN ir_data->* TO <lt_table>.
    IF sy-subrc <> 0.
      MESSAGE 'Failed to assign dynamic data' TYPE 'E'.
      RETURN.
    ENDIF.

    CASE iv_format.
      WHEN 'CSV'. iv_filename = iv_filename && '.csv'.
      WHEN 'XML'. iv_filename = iv_filename && '.xml'.
      WHEN 'XLS'. iv_filename = iv_filename && '.xls'.
    ENDCASE.

    lv_full_path = |{ iv_directory }/{ iv_filename }|.
    lv_content   = convert_to_format( ir_data = ir_data iv_format = iv_format
                                      it_field_names = it_field_names ).

    SPLIT lv_content AT cl_abap_char_utilities=>newline INTO TABLE lt_lines.

    OPEN DATASET lv_full_path FOR OUTPUT IN TEXT MODE ENCODING DEFAULT.
    IF sy-subrc = 0.
      LOOP AT lt_lines INTO lv_line.
        TRANSFER lv_line TO lv_full_path.
      ENDLOOP.
      CLOSE DATASET lv_full_path.
    ELSE.
      MESSAGE 'Error writing to AL11 path' TYPE 'E'.
    ENDIF.


  ENDMETHOD.
ENDCLASS.
