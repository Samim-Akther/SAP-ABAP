FORM parse_lines2 .

  DATA: l_string(44) TYPE c,
        l_tablines   TYPE i,
        l_lenght     TYPE i,
        lv_index     TYPE sy-tabix,
        lv_error(50) TYPE c.

  DATA lv_error_line TYPE c LENGTH 1.

  DATA: lt_fields LIKE STANDARD TABLE OF l_string.

  LOOP AT i_lines ASSIGNING <fs_line>.
    lv_index = sy-tabix.
    CLEAR lv_error_line.
    TRY .

        IF <fs_line> CA space.

          l_string = <fs_line>.

          SPLIT l_string AT ',' INTO TABLE lt_fields.

          DESCRIBE TABLE lt_fields LINES l_tablines.

          wa_data-werks = va_werks.
          IF l_tablines EQ 4.
            READ TABLE lt_fields INTO wa_data-datum INDEX 1.
            READ TABLE lt_fields INTO wa_data-uzeit INDEX 2.
            READ TABLE lt_fields INTO wa_data-zpal_line INDEX 3.
            READ TABLE lt_fields INTO wa_data-zbox INDEX 4.

            PERFORM get_aufnr_value USING wa_data-zbox CHANGING wa_data-aufnr.
            PERFORM get_hu USING wa_data-zbox CHANGING wa_data-box_hu_num.
            APPEND wa_data TO i_data.
            CLEAR wa_data.
          ELSE.
            lv_error_line = abap_true.
            MESSAGE s208(00) WITH 'ERROR PARSING LINE'.
            lv_error = 'ERROR PARSING LINE'.
          ENDIF.
        ELSE.
          lv_error_line = abap_true.
          MESSAGE s208(00) WITH 'ERROR PARSING LINE'.
          lv_error = 'ERROR PARSING LINE'.
        ENDIF.

      CATCH cx_root.
        lv_error_line = abap_true.
    ENDTRY.
    IF lv_error_line IS NOT INITIAL .
*      PERFORM f_send_line_error USING <fs_line>
*                                      lv_index.
      CLEAR wa_error.
      wa_error-zmessage     = lv_error.
      APPEND wa_error TO tb_error.

    ENDIF.
  ENDLOOP.

ENDFORM.
