FORM f_update_batch_characteristics USING  lw_data  TYPE zif_00002
                                  CHANGING lt_items TYPE tb_item.

  DATA: l_objectkey TYPE bapi1003_key-object,
        l_classnum  TYPE bapi1003_key-classnum,
        l_status    TYPE bapi1003_key-status,
        l_objek     TYPE kssk-objek.

  DATA: lt_valuesnum  TYPE STANDARD TABLE OF bapi1003_alloc_values_num,
        lt_valueschar TYPE STANDARD TABLE OF bapi1003_alloc_values_char,
        lt_aluescurr  TYPE STANDARD TABLE OF bapi1003_alloc_values_curr,
        lt_return     TYPE STANDARD TABLE OF bapiret2.

  FIELD-SYMBOLS: <lfs_item> TYPE bapi2017_gm_item_create,
                 <lfs_mch1> TYPE ty_mch1,
                 <lfs_inob> TYPE ty_inob,
                 <lfs_kssk> TYPE ty_kssk,
                 <lfs_klah> TYPE ty_klah.


  SORT: i_mch1 BY matnr charg,
        i_inob_obj BY cuobj,
        i_inob_cls BY objek,
        i_kssk BY objek,
        i_klah BY clint.

  LOOP AT lt_items ASSIGNING <lfs_item>.

*   Get OBJECTKEY value
*----------------------------------------------------------------------*
    READ TABLE i_mch1
               ASSIGNING <lfs_mch1>
                         WITH KEY matnr = <lfs_item>-material
                                  charg = <lfs_item>-batch
                         BINARY SEARCH.
    IF sy-subrc IS INITIAL.
      READ TABLE i_inob_obj
               ASSIGNING <lfs_inob>
                         WITH KEY cuobj = <lfs_mch1>-cuobj_bm
                         BINARY SEARCH.
      IF sy-subrc IS INITIAL.
        l_objectkey = <lfs_inob>-objek.
      ENDIF.
    ENDIF.

*   Get CLASSNUM value
*----------------------------------------------------------------------*
    READ TABLE i_inob_cls
               ASSIGNING <lfs_inob>
                         WITH KEY objek = <lfs_item>-material
                         BINARY SEARCH.
    IF sy-subrc IS INITIAL.
      CLEAR l_objek.
      l_objek = <lfs_inob>-cuobj.
      READ TABLE i_kssk
                 ASSIGNING <lfs_kssk>
                           WITH KEY objek = l_objek
                           BINARY SEARCH.
      IF sy-subrc IS INITIAL.
        READ TABLE i_klah
                 ASSIGNING <lfs_klah>
                           WITH KEY clint = <lfs_kssk>-clint
                           BINARY SEARCH.
        IF sy-subrc IS INITIAL.
          l_classnum = <lfs_klah>-class.
        ENDIF.
      ENDIF.
    ENDIF.

    CALL FUNCTION 'BAPI_OBJCL_GETDETAIL'
      EXPORTING
        objectkey        = l_objectkey
        objecttable      = 'MCH1'
        classnum         = l_classnum
        classtype        = '023'
        keydate          = lw_data-datum
        unvaluated_chars = 'X'
        language         = sy-langu
      IMPORTING
        status           = l_status
*       STANDARDCLASS    =
      TABLES
        allocvaluesnum   = lt_valuesnum
        allocvalueschar  = lt_valueschar
        allocvaluescurr  = lt_aluescurr
        return           = lt_return.

    IF l_status EQ 1.

      PERFORM f_objcl_change USING l_classnum
                                   lw_data
                                   <lfs_item>
                             CHANGING lt_valuesnum
                                      lt_valueschar
                                      lt_aluescurr.
    ELSE.
*     APPEND DATA TO ERROR MAIL No.4
*----------------------------------------------------------------------*
      PERFORM f_append_msg_to_mail_4 USING lw_data
                                   CHANGING lt_return.
    ENDIF.

  ENDLOOP.

