FORM f_object_class  USING    p_goodsmvt  TYPE zgoodsmvt_app_s
                     CHANGING c_error     TYPE xflag
                              lt_klah     TYPE tb_klah
                              lt_inob     TYPE tb_inob
                              lt_kssk     TYPE tb_kssk
                              lt_mch1_obj TYPE tb_mch1
                              lt_inob_obj TYPE tb_inob.


  DATA: l_class  TYPE klah-class,
        l_object TYPE ausp-objek.

