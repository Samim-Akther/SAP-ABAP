FORM f_get_pkhd_lqua_data .

  DATA: lr_lgnum    TYPE STANDARD TABLE OF hrranges,
        lr_lgpla    TYPE STANDARD TABLE OF hrranges,
        lr_lgtyp    TYPE STANDARD TABLE OF hrranges,
        lw_ranges_a TYPE hrranges,
        lw_ranges_b TYPE hrranges.

  DATA: lt_resb TYPE STANDARD TABLE OF resb.

  FIELD-SYMBOLS: <lfs_t320> TYPE ty_t320,
                 <lfs_pkhd> TYPE ty_pkhd.

  IF i_resb IS NOT INITIAL.
    lt_resb[] = i_resb[].

    SORT lt_resb BY matnr werks prvbe.
    DELETE ADJACENT DUPLICATES
                    FROM lt_resb
                         COMPARING matnr werks prvbe.
    SELECT pknum
           matnr
           werks
           prvbe
           lgnum
           lgtyp
           lgpla
      FROM pkhd INTO TABLE i_pkhd
      FOR ALL ENTRIES IN lt_resb
      WHERE   matnr = lt_resb-matnr
          AND werks = lt_resb-werks
          AND prvbe = lt_resb-prvbe.


    LOOP AT i_t320 ASSIGNING <lfs_t320>.
      lw_ranges_a-sign = 'I'.
      lw_ranges_a-opti = 'EQ'.
      lw_ranges_a-low = <lfs_t320>-lgnum.

      APPEND lw_ranges_a TO lr_lgnum.
      CLEAR lw_ranges_a.
    ENDLOOP.

    DELETE i_pkhd WHERE lgnum NOT IN lr_lgnum.


    LOOP AT i_pkhd ASSIGNING <lfs_pkhd>.
      lw_ranges_a-sign = 'I'.
      lw_ranges_a-opti = 'EQ'.
      lw_ranges_a-low = <lfs_pkhd>-lgtyp.

      lw_ranges_b-sign = 'I'.
      lw_ranges_b-opti = 'EQ'.
      lw_ranges_b-low = <lfs_pkhd>-lgpla.

      APPEND lw_ranges_a TO lr_lgtyp.
      APPEND lw_ranges_b TO lr_lgpla.
      CLEAR lw_ranges_a.
      CLEAR lw_ranges_b.
    ENDLOOP.

    lt_resb[] = i_resb[].
    SORT lt_resb BY matnr werks.
    DELETE ADJACENT DUPLICATES
                    FROM lt_resb
                         COMPARING matnr werks.
    SELECT lgnum
           lqnum
           matnr
           werks
           charg
           lgtyp
           lgpla
           edatu
           ezeit
           verme
      FROM lqua INTO TABLE i_lqua
      FOR ALL ENTRIES IN lt_resb
      WHERE   matnr = lt_resb-matnr
          AND werks = lt_resb-werks.

    DELETE i_lqua WHERE lgnum NOT IN lr_lgnum.
    DELETE i_lqua WHERE lgtyp NOT IN lr_lgtyp.
    DELETE i_lqua WHERE lgpla NOT IN lr_lgpla.
* UPDATE 18.12.2015   - START
*    DELETE i_lqua WHERE verme IS INITIAL. "SS19.06.2015 11:24:29
    DELETE i_lqua WHERE verme LE 0.
* UPDATE 18.12.2015   - END

    FREE lt_resb.
  ENDIF.

