FORM f_read_class_values CHANGING lt_inob TYPE tb_inob
                                  lt_kssk TYPE tb_kssk
                                  lt_klah TYPE tb_klah.

  DATA: lr_objek TYPE RANGE OF inob-objek.

  DATA: l_objek LIKE LINE OF lr_objek.

  FIELD-SYMBOLS: <lfs_inob> TYPE ty_inob,
                 <lfs_resb> TYPE resb.

  LOOP AT i_resb ASSIGNING <lfs_resb>.
    l_objek-sign = 'I'.
    l_objek-option = 'EQ'.
    l_objek-low = <lfs_resb>-matnr.
    APPEND l_objek TO lr_objek.
    CLEAR l_objek.
  ENDLOOP.

  IF lr_objek IS NOT INITIAL.   "CAP_GG
    SELECT cuobj
           klart
           obtab
           objek
      FROM inob INTO TABLE lt_inob
      WHERE   klart = '023'
          AND obtab = 'MARA'
          AND objek IN lr_objek.

    IF  lt_inob IS NOT INITIAL.
      REFRESH lr_objek.
      LOOP AT lt_inob ASSIGNING <lfs_inob>.
        l_objek-sign = 'I'.
        l_objek-option = 'EQ'.
        l_objek-low = <lfs_inob>-cuobj.
        APPEND l_objek TO lr_objek.
        CLEAR l_objek.
      ENDLOOP.

      SELECT objek
             mafid
             klart
             clint
             adzhl
        FROM kssk INTO TABLE lt_kssk
        WHERE   objek IN lr_objek
            AND klart = '023'.
    ENDIF.

    IF lt_kssk IS NOT INITIAL.
      SELECT clint
             class
        FROM klah INTO TABLE lt_klah
        FOR ALL ENTRIES IN lt_kssk
        WHERE clint = lt_kssk-clint.
    ENDIF.
  ENDIF.    "CAP_GG

