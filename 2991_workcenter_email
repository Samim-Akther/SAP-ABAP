*&---------------------------------------------------------------------*
FORM f_matnr_is_flat
  USING     pv_matnr  TYPE mara-matnr
            pv_werks  TYPE t001w-werks
  CHANGING  pf_flat   TYPE xfeld.

  STATICS:
    sv_flatcharact TYPE cabn-atnam,
    sr_flatvalue   TYPE RANGE OF ausp-atwrt.
  DATA:
    lt_characteristic TYPE zcharacteristic_t,
    lt_matnr          TYPE matnr_tty.

  IF sv_flatcharact IS INITIAL.
    CALL FUNCTION 'ZXUN_GET_PARAMETER_YSVARV'
      EXPORTING
        i_progname      = 'ZLRN_PRODUCTION_DASHBOARD'
        i_name          = 'ZIF_CTFLAT'
      IMPORTING
        p_result        = sv_flatcharact
      EXCEPTIONS
        wrong_type      = 1
        wrong_value     = 2
        inchoerent_type = 3
        OTHERS          = 4.
    IF sy-subrc IS NOT INITIAL. ENDIF.
  ENDIF.

  IF sr_flatvalue[] IS INITIAL.
    CALL FUNCTION 'ZXUN_GET_RANGE_YSVARV'
      EXPORTING
        i_progname      = 'ZLRN_PRODUCTION_DASHBOARD'
        i_name          = 'ZIF_CTFLAT_VALUE'
      CHANGING
        e_range         = sr_flatvalue[]
      EXCEPTIONS
        wrong_type      = 1
        wrong_value     = 2
        inchoerent_type = 3
        OTHERS          = 4.
    IF sy-subrc IS NOT INITIAL. ENDIF.
  ENDIF.

  APPEND pv_matnr TO lt_matnr.

  CALL FUNCTION 'ZLUN_CHARACTERISTIC'
    EXPORTING
      i_werks           = pv_werks
      it_matnr          = lt_matnr
    IMPORTING
      et_characteristic = lt_characteristic
    EXCEPTIONS
      no_zxysvarv       = 1
      OTHERS            = 2.
  IF sy-subrc IS INITIAL.
    READ TABLE lt_characteristic
      ASSIGNING FIELD-SYMBOL(<lf_characteristic>)
      WITH KEY matnr = pv_matnr
               atnam = sv_flatcharact.
    IF sy-subrc IS INITIAL  AND
       <lf_characteristic>-atwrt IN sr_flatvalue.
      pf_flat = abap_true.

    ELSE.
      pf_flat = abap_false.
    ENDIF.

  ELSE.
    pf_flat = abap_false.
  ENDIF.
ENDFORM.
