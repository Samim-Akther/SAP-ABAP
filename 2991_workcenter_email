    IF sy-subrc = 0.
      LOOP AT lt_resb_ps ASSIGNING <fs_resb>.
        DELETE lt_resb WHERE matnr EQ <fs_resb>-matnr.
      ENDLOOP.
    ENDIF.
*    <-- SEDA UK remove consumption of printing_slitting components FM 09022026

    PERFORM f_get_characteristic_r USING 'ZIF_MATGRPACKBOX'
                                CHANGING lr_mtgrbox.

    "	Retrieve from the internal table I_RESB the material that has to be assigned
    SELECT
        matnr,
        mtart,
        magrv
      FROM mara
      INTO TABLE @DATA(lt_mara)
      FOR ALL ENTRIES IN @lt_resb
      WHERE matnr EQ @lt_resb-matnr.

    CALL FUNCTION 'ZXUN_GET_PARAM_YSVARV'
      EXPORTING
        i_progname      = 'ZLIN_COMBO'
        i_name          = 'ZPACK_MAT'
        i_type          = 'S'
*       i_numb          = 0000
      TABLES
        it_hrranges     = lt_hrranges
      EXCEPTIONS
        wrong_type      = 1
        wrong_value     = 2
        inchoerent_type = 3
        OTHERS          = 4.
    IF sy-subrc IS INITIAL.
      LOOP AT lt_hrranges INTO DATA(wa_hrranges).
        MOVE wa_hrranges-sign TO wa_mtart-sign.
        MOVE wa_hrranges-opti TO wa_mtart-option.
        MOVE wa_hrranges-low  TO wa_mtart-low.
        MOVE wa_hrranges-high TO wa_mtart-high.
        APPEND wa_mtart TO lr_mtart.
        CLEAR wa_mtart.
      ENDLOOP.
    ENDIF.

    LOOP AT lt_mara INTO DATA(ls_mara) WHERE mtart IN lr_mtart
                                         AND magrv NOT IN lr_mtgrbox.
      READ TABLE lt_resb INTO DATA(ls_resb)
                           WITH KEY matnr = ls_mara-matnr.
      IF sy-subrc IS INITIAL.
        DELETE lt_resb INDEX sy-tabix.
      ENDIF.
    ENDLOOP.


    "	Retrieve all the SU assigned to the production order
    SELECT * FROM zpp_trace_su_con INTO TABLE @DATA(lt_zpp_trace_su_con)
      WHERE aufnr  EQ @lw_data-aufnr
        AND werks  EQ @lw_data-werks
        AND closed EQ @space.

    LOOP AT lt_resb ASSIGNING <lfs_resb>.
      READ TABLE i_afpo ASSIGNING <lfs_afpo>
                          WITH KEY aufnr = <lfs_resb>-aufnr
                          BINARY SEARCH.
      CHECK sy-subrc IS INITIAL.

      "	Check that for each material code contained in the updated RESB there is an assigned SU
      READ TABLE lt_zpp_trace_su_con TRANSPORTING NO FIELDS  "INTO DATA(ls_zpp_trace_su_con)
      WITH KEY matnr = <lfs_resb>-matnr.
      IF sy-subrc IS NOT INITIAL. "se non abbiamo nessun record con i matnr dei resb
*<<<NDC - Begin of Modify - 15.03.2021 - IF
*        WRITE <lfs_resb>-matnr TO l_cv1.
*        WRITE lw_data-aufnr TO l_cv2.
*        SHIFT l_cv2 LEFT DELETING LEADING '0'.
*        CLEAR wa_error.
*        MESSAGE e191(zc_ftd_pp)
*        WITH l_cv1 l_cv2 INTO wa_error-zmessage .
        MESSAGE e058(zc_ftd_pp) INTO wa_error-zmessage.
*>>>NDC - End of Modify - 15.03.2021 - IF
        wa_error-zbox = lw_data-zbox.
        APPEND wa_error TO tb_error.
        lv_error = abap_true.
      ELSE. "se abbiamo dei risultati
        CLEAR lv_compqty.
*Begin of ins S01K910878 E.M.
        CLEAR ls_mara.
        READ TABLE lt_mara INTO ls_mara
        WITH KEY matnr = <lfs_resb>-matnr.
        IF ls_mara-magrv IN lr_mtgrbox.
          lv_compqty = 1.

        ELSE.
*End of ins S01K910878 E.M.
* -> 14/05/21 S.C.
          PERFORM f_matnr_is_flat
            USING     <lfs_afpo>-matnr
                      lw_data-werks
            CHANGING  lv_is_flat.
          IF lv_is_flat IS INITIAL.
            CALL FUNCTION 'MARA_SINGLE_READ'
              EXPORTING
                matnr             = <lfs_afpo>-matnr
              IMPORTING
                wmara             = ls_mara_afpo
              EXCEPTIONS
                lock_on_material  = 1
                lock_system_error = 2
                wrong_call        = 3
                not_found         = 4
                OTHERS            = 5.
            IF sy-subrc IS INITIAL.
              CALL FUNCTION 'MD_CONVERT_MATERIAL_UNIT'
                EXPORTING
                  i_matnr              = ls_mara_afpo-matnr
                  i_in_me              = 'ST'
                  i_out_me             = ls_mara_afpo-meins
                  i_menge              = CONV ekpo-menge( p_pcexbox )
                IMPORTING
                  e_menge              = lv_pcexbox
                EXCEPTIONS
                  error_in_application = 1
                  error                = 2
                  OTHERS               = 3.
              IF sy-subrc IS NOT INITIAL.
                lv_pcexbox = 0.
              ENDIF.

            ELSE.
              lv_pcexbox = 0.
            ENDIF.

          ELSE.
            lv_pcexbox = p_pcexbox.
          ENDIF.
* <- 14/05/21 S.C.

          IF <lfs_resb>-netau IS NOT INITIAL.
            lv_compqty = ( ( <lfs_resb>-erfmg / ( 1 + ( <lfs_resb>-ausch / 100 ) ) )
*              * p_pcexbox ) /
              * lv_pcexbox ) / "14/05/21 S.C.
              ( ( <lfs_afpo>-psmng - <lfs_afpo>-psamg ) *
                    <lfs_afpo>-umrez / <lfs_afpo>-umren ) .
          ELSE.
            lv_compqty = ( ( <lfs_resb>-erfmg / ( 1 + ( <lfs_resb>-ausch / 100 ) ) )
*              * p_pcexbox ) /
              * lv_pcexbox ) / "14/05/21 S.C.
              ( ( <lfs_afpo>-psmng ) * <lfs_afpo>-umrez / <lfs_afpo>-umren ) .
          ENDIF.
*Begin of ins S01K910878 E.M.
        ENDIF.
*End of ins S01K910878 E.M.

        "to check that the assigned quantity to the production order is greater than the quantity to be consumed.
        SELECT SUM( nista_in ), altme_in
          FROM zpp_trace_su_con
          INTO ( @lv_available_qty , @lv_altme_in )
          WHERE aufnr  EQ @lw_data-aufnr
            AND werks  EQ @lw_data-werks
            AND matnr  EQ @<lfs_resb>-matnr
            AND closed EQ @space
          GROUP BY altme_in.
        ENDSELECT.

        IF lv_compqty GT lv_available_qty.
          IF lv_error IS INITIAL.
            WRITE <lfs_resb>-matnr TO l_cv1.
            WRITE lw_data-aufnr TO l_cv2.
            SHIFT l_cv2 LEFT DELETING LEADING '0'.
            CLEAR wa_error.
            MESSAGE e191(zc_ftd_pp)
            WITH l_cv1 l_cv2 INTO wa_error-zmessage .
            wa_error-zbox = lw_data-zbox.
            APPEND wa_error TO tb_error.
            lv_error = abap_true.
          ENDIF.
        ENDIF.
        "Reference [SEDA_MF_013_08_FD_04]
        SELECT lgnum, lqnum, matnr, werks, charg,
               lgtyp, lgpla, meins, verme, lgort
          FROM lqua
          INTO TABLE @DATA(lt_lqua)
          FOR ALL ENTRIES IN @lt_zpp_trace_su_con
          WHERE lgnum EQ @lt_zpp_trace_su_con-lgnum
            AND matnr EQ @lt_zpp_trace_su_con-matnr
            AND werks EQ @lt_zpp_trace_su_con-werks
            AND charg EQ @lt_zpp_trace_su_con-charg
            AND lgtyp EQ @lt_zpp_trace_su_con-lgtyp
            AND lgpla EQ @lt_zpp_trace_su_con-lgpla
            AND lgort EQ @lt_zpp_trace_su_con-lgort.

        SORT lt_lqua BY verme.
        DELETE lt_lqua WHERE verme <= 0.
        SORT lt_lqua BY lgnum matnr werks charg lgtyp lgpla lgort.
        SORT lt_zpp_trace_su_con BY cre_date cre_time.

        "Prepare the LT_ITEM, LT_ITEM_APP to pass the BAPI_GOODSMVT_CREATE
        LOOP AT lt_zpp_trace_su_con INTO DATA(ls_zpp_trace_su_con) WHERE matnr EQ <lfs_resb>-matnr.
          READ TABLE lt_lqua INTO DATA(ls_lqua)
                              WITH KEY lgnum = ls_zpp_trace_su_con-lgnum
                                       matnr = ls_zpp_trace_su_con-matnr
                                       werks = ls_zpp_trace_su_con-werks
                                       charg = ls_zpp_trace_su_con-charg
                                       lgtyp = ls_zpp_trace_su_con-lgtyp
                                       lgpla = ls_zpp_trace_su_con-lgpla
                                       lgort = ls_zpp_trace_su_con-lgort
                                       BINARY SEARCH.
          IF sy-subrc IS INITIAL AND lv_compqty NE 0.
            wa_items-reserv_no = <lfs_resb>-rsnum.
            wa_items-res_item  = <lfs_resb>-rspos.
            wa_items-material  = <lfs_resb>-matnr.
            wa_items-plant     = <lfs_resb>-werks.
            wa_items-stge_loc  = <lfs_resb>-lgort.
            wa_items-batch     = ls_zpp_trace_su_con-charg.
            wa_items-entry_uom = <lfs_resb>-erfme.
            wa_items-orderid   = <lfs_resb>-aufnr.
            wa_items-stge_type = ls_zpp_trace_su_con-lgtyp.
            wa_items-stge_bin  = ls_zpp_trace_su_con-lgpla.
            wa_items-move_type = '261'.
            IF ls_lqua-meins NE ls_resb-erfme.
              CLEAR: lv_matnr, lv_uom_in, lv_uom_out, lv_qty_in, lv_qty_out.

              lv_matnr   = <lfs_resb>-matnr.
              lv_uom_in  = ls_lqua-meins.
              lv_uom_out = <lfs_resb>-erfme.
              lv_qty_in  = ls_lqua-verme.
              CALL FUNCTION 'MD_CONVERT_MATERIAL_UNIT'
                EXPORTING
                  i_matnr              = lv_matnr
                  i_in_me              = lv_uom_in
                  i_out_me             = lv_uom_out
                  i_menge              = lv_qty_in
                IMPORTING
                  e_menge              = lv_qty_out
                EXCEPTIONS
                  error_in_application = 1
                  error                = 2
                  OTHERS               = 3.
              IF sy-subrc IS NOT INITIAL.
                CALL FUNCTION 'UNIT_CONVERSION_SIMPLE'
                  EXPORTING
                    input                = lv_qty_in
                    no_type_check        = ' '
                    round_sign           = ' '
                    unit_in              = lv_uom_in
                    unit_out             = lv_uom_out
                  IMPORTING
                    output               = lv_qty_out
                  EXCEPTIONS
                    conversion_not_found = 1
                    division_by_zero     = 2
                    input_invalid        = 3
                    output_invalid       = 4
                    overflow             = 5
                    type_invalid         = 6
                    units_missing        = 7
                    unit_in_not_found    = 8
                    unit_out_not_found   = 9
                    OTHERS               = 10.
              ENDIF.
              IF sy-subrc IS INITIAL.
                ls_lqua-verme = lv_qty_out.
              ELSE.
                IF lv_error IS INITIAL.
                  WRITE <lfs_resb>-matnr TO l_cv1.
                  WRITE lw_data-aufnr TO l_cv2.
                  SHIFT l_cv2 LEFT DELETING LEADING '0'.
                  CLEAR wa_error.
                  MESSAGE e191(zc_ftd_pp)
                  WITH l_cv1 l_cv2 INTO wa_error-zmessage .
                  wa_error-zbox = lw_data-zbox.
                  APPEND wa_error TO tb_error.
                  lv_error = abap_true.
                  RETURN.
                ENDIF.
              ENDIF.
            ENDIF.

            IF ls_zpp_trace_su_con-nista_in > ls_lqua-verme.
              ls_zpp_trace_su_con-nista_in = ls_lqua-verme.
            ENDIF.
            IF ls_zpp_trace_su_con-nista_in >= lv_compqty.
              wa_items-entry_qnt = lv_compqty.
*              CLEAR lv_compqty.

              ls_items_app-material  = wa_items-material.
              ls_items_app-plant     = wa_items-plant.
              ls_items_app-stge_loc  = wa_items-stge_loc.
              ls_items_app-batch     = wa_items-batch.
              ls_items_app-move_type = wa_items-move_type.
              ls_items_app-entry_uom = wa_items-entry_uom.
              ls_items_app-orderid   = wa_items-orderid.
              ls_items_app-entry_qnt = wa_items-entry_qnt.
              ls_items_app-vlenr = ls_zpp_trace_su_con-lenum_in.
