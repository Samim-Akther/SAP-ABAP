    IF sy-subrc IS INITIAL.
      READ TABLE lt_klah
                  ASSIGNING <lfs_klah>
                            WITH KEY clint = <lfs_kssk>-clint
                            BINARY SEARCH.
      IF sy-subrc IS INITIAL.
        l_class = <lfs_klah>-class.
