        lt_objdata TYPE STANDARD TABLE OF clobjdat.

  FIELD-SYMBOLS: <lfs_inob> TYPE ty_inob,
                 <lfs_kssk> TYPE ty_kssk,
                 <lfs_klah> TYPE ty_klah,
                 <lfs_mch1> TYPE ty_mch1.

