    CALL FUNCTION 'ZLIN_GET_PRINT_SLIT'
      EXPORTING
        i_aufnr      = lw_data-aufnr
*     IMPORTING
*       O_MATNR      =
      TABLES
        o_resb       = lt_resb_ps
      EXCEPTIONS
        no_charact   = 1
        no_value     = 2
        no_component = 3
