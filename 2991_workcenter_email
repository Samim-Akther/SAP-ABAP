          PERFORM f_append_msg_to_mail_2 USING p_matnr
                                               lw_data
                                         CHANGING lt_items
                                                  lt_return.

        ENDIF.
      ENDIF.  "SS22.06.2015 15:13:34
    ENDIF.

    "Begin of ins  S01K910878 24/04/2020 E.M.
  ELSE.

    FIELD-SYMBOLS: <lfs_afpo> LIKE LINE OF i_afpo.

    REFRESH lt_resb.
    SELECT * FROM resb
      INTO TABLE lt_resb
      WHERE aufnr = lw_data-aufnr
      AND xloek = space
      AND shkzg = 'H'
      AND postp = 'L'
      AND schgt = space
      AND dumps = space
      AND fmeng = space.

    PERFORM f_get_characteristic_r
        USING 'ZIF_MATGRPACKBOX' CHANGING lr_mtgrbox.

    SELECT
        matnr,
        mtart,
        magrv,
        meins "14/05/21 S.C.
    FROM mara
    INTO TABLE @DATA(lt_mara)
    FOR ALL ENTRIES IN @lt_resb
    WHERE matnr EQ @lt_resb-matnr.
    DATA: lw_mara LIKE LINE OF lt_mara.

    REFRESH: lt_hrranges, lr_mtart.
    CALL FUNCTION 'ZXUN_GET_PARAM_YSVARV'
      EXPORTING
        i_progname      = 'ZLIN_COMBO'
        i_name          = 'ZPACK_MAT'
        i_type          = 'S'
*       i_numb          = 0000
      TABLES
        it_hrranges     = lt_hrranges
      EXCEPTIONS
        wrong_type      = 1
        wrong_value     = 2
        inchoerent_type = 3
        OTHERS          = 4.
    IF sy-subrc IS INITIAL.
      LOOP AT lt_hrranges INTO DATA(wa_hrranges).
        CLEAR wa_mtart.
        MOVE wa_hrranges-sign TO wa_mtart-sign.
        MOVE wa_hrranges-opti TO wa_mtart-option.
        MOVE wa_hrranges-low  TO wa_mtart-low.
        MOVE wa_hrranges-high TO wa_mtart-high.
        APPEND wa_mtart TO lr_mtart.
        CLEAR wa_mtart.
      ENDLOOP.
    ENDIF.

    LOOP AT lt_mara INTO DATA(ls_mara) WHERE mtart IN lr_mtart
                                         AND magrv NOT IN lr_mtgrbox.
      READ TABLE lt_resb INTO DATA(ls_resb)
                           WITH KEY matnr = ls_mara-matnr.
      IF sy-subrc IS INITIAL.
        DELETE lt_resb INDEX sy-tabix.
      ENDIF.
    ENDLOOP.

    REFRESH lt_zpp_trace_su_con.
    SELECT * FROM zpp_trace_su_con
      INTO TABLE lt_zpp_trace_su_con
      WHERE aufnr = lw_data-aufnr
      AND werks = lw_data-werks
      AND closed = space.

    LOOP AT lt_resb INTO ls_resb.
      READ TABLE i_afpo ASSIGNING <lfs_afpo>
                    WITH KEY aufnr = ls_resb-aufnr
                    BINARY SEARCH.
      CHECK sy-subrc IS INITIAL.

      CLEAR ls_zpp_trace_su_con.
      READ TABLE lt_zpp_trace_su_con INTO ls_zpp_trace_su_con
      WITH KEY matnr = ls_resb-matnr.
      IF sy-subrc IS NOT INITIAL.
        lv_error = 'X'.
        PERFORM f_append_msg_to_mail_6 USING ls_resb-matnr
" Begin Insert A.G. 04.08.2020 15:27:18
                                             lw_data.
        " End Insert A.G 04.08.2020 15:27:18
        EXIT.
      ENDIF.
    ENDLOOP.

    IF lv_error = space.
*  Reference with [SEDA_MF_013_06_FD_06] and [SEDA_MF_013_06_FD_07]
      SELECT lgnum, lqnum, matnr, werks, charg,
             lgtyp, lgpla, meins, verme, lgort
        FROM lqua
        INTO TABLE @DATA(lt_lqua)
        FOR ALL ENTRIES IN @lt_zpp_trace_su_con
        WHERE lgnum EQ @lt_zpp_trace_su_con-lgnum
          AND matnr EQ @lt_zpp_trace_su_con-matnr
          AND werks EQ @lt_zpp_trace_su_con-werks
          AND charg EQ @lt_zpp_trace_su_con-charg
          AND lgtyp EQ @lt_zpp_trace_su_con-lgtyp
          AND lgpla EQ @lt_zpp_trace_su_con-lgpla
          AND lgort EQ @lt_zpp_trace_su_con-lgort.
      DATA: lw_lqua LIKE LINE OF lt_lqua.

      SORT lt_lqua BY verme.
      DELETE lt_lqua WHERE verme <= 0.
      SORT lt_lqua BY lgnum matnr werks charg lgtyp lgpla lgort.
      SORT lt_zpp_trace_su_con BY cre_date cre_time.

      CLEAR lw_header.
      lw_header-pstng_date = sy-datum.
      lw_header-doc_date = lw_data-datum.
      lw_header-header_txt = lw_data-zbox.

      LOOP AT lt_resb INTO lw_resb.
        READ TABLE lt_mara INTO lw_mara WITH KEY matnr = lw_resb-matnr.
        IF sy-subrc IS NOT INITIAL.
          CLEAR lw_mara.

        ELSE.
          IF lw_mara-magrv IN lr_mtgrbox.
            l_compqty = 1.

          ELSE.
* -> 14/05/21 S.C.
            CALL FUNCTION 'MARA_SINGLE_READ'
              EXPORTING
                matnr             = <lfs_afpo>-matnr
              IMPORTING
                wmara             = ls_mara_afpo
              EXCEPTIONS
                lock_on_material  = 1
                lock_system_error = 2
                wrong_call        = 3
                not_found         = 4
                OTHERS            = 5.
            IF sy-subrc IS INITIAL.
              CALL FUNCTION 'MD_CONVERT_MATERIAL_UNIT'
                EXPORTING
                  i_matnr              = ls_mara_afpo-matnr
                  i_in_me              = 'ST'
                  i_out_me             = ls_mara_afpo-meins
                  i_menge              = CONV ekpo-menge( p_pcexbox )
                IMPORTING
                  e_menge              = lv_pcexbox
                EXCEPTIONS
                  error_in_application = 1
                  error                = 2
                  OTHERS               = 3.
              IF sy-subrc IS NOT INITIAL.
                lv_pcexbox = 0.
              ENDIF.

            ELSE.
              lv_pcexbox = 0.
            ENDIF.
* <- 14/05/21 S.C.

            IF lw_resb-netau IS NOT INITIAL.
              l_compqty = ( ( lw_resb-erfmg / ( 1 + ( lw_resb-ausch / 100 ) ) )
*                * p_pcexbox ) /
                * lv_pcexbox ) / "14/05/21 S.C.
              ( ( <lfs_afpo>-psmng - <lfs_afpo>-psamg ) *
              <lfs_afpo>-umrez / <lfs_afpo>-umren ).
            ELSE.
              l_compqty = ( ( lw_resb-erfmg / ( 1 + ( lw_resb-ausch / 100 ) ) )
*                * p_pcexbox ) /
                * lv_pcexbox ) / "14/05/21 S.C.
              ( ( <lfs_afpo>-psmng )
              * <lfs_afpo>-umrez / <lfs_afpo>-umren ).
            ENDIF.
          ENDIF.

          LOOP AT lt_zpp_trace_su_con INTO ls_zpp_trace_su_con
            WHERE matnr = lw_resb-matnr.
            READ TABLE lt_lqua INTO lw_lqua
                  WITH KEY lgnum = ls_zpp_trace_su_con-lgnum
                             matnr = ls_zpp_trace_su_con-matnr
                             werks = ls_zpp_trace_su_con-werks
                             charg = ls_zpp_trace_su_con-charg
                             lgtyp = ls_zpp_trace_su_con-lgtyp
                             lgpla = ls_zpp_trace_su_con-lgpla
                             lgort = ls_zpp_trace_su_con-lgort
                             BINARY SEARCH.
            IF sy-subrc IS INITIAL.
              lw_item-reserv_no = lw_resb-rsnum.
              lw_item-res_item = lw_resb-rspos.
              lw_item-material = lw_resb-matnr.
              lw_item-plant = lw_resb-werks.
              lw_item-stge_loc = lw_resb-lgort.
              lw_item-batch = ls_zpp_trace_su_con-charg.
              lw_item-entry_uom = lw_resb-erfme.
              lw_item-orderid = lw_resb-aufnr.
              lw_item-stge_type = ls_zpp_trace_su_con-lgtyp.
              lw_item-stge_bin = ls_zpp_trace_su_con-lgpla.
              lw_item-move_type = '261'.

              IF lw_lqua-meins NE lw_resb-erfme.
                CLEAR: lv_matnr, lv_uom_in, lv_uom_out, lv_qty_in, lv_qty_out.

                lv_matnr = lw_resb-matnr.
                lv_uom_in = lw_lqua-meins.
                lv_uom_out = lw_resb-erfme.
                lv_qty_in = lw_lqua-verme.

                CALL FUNCTION 'MD_CONVERT_MATERIAL_UNIT'
                  EXPORTING
                    i_matnr              = lv_matnr
                    i_in_me              = lv_uom_in
                    i_out_me             = lv_uom_out
                    i_menge              = lv_qty_in
                  IMPORTING
                    e_menge              = lv_qty_out
                  EXCEPTIONS
                    error_in_application = 1
                    error                = 2
                    OTHERS               = 3.
                IF sy-subrc IS NOT INITIAL.
                  CALL FUNCTION 'UNIT_CONVERSION_SIMPLE'
                    EXPORTING
                      input                = lv_qty_in
                      no_type_check        = ' '
                      round_sign           = ' '
                      unit_in              = lv_uom_in
                      unit_out             = lv_uom_out
                    IMPORTING
                      output               = lv_qty_out
                    EXCEPTIONS
                      conversion_not_found = 1
                      division_by_zero     = 2
                      input_invalid        = 3
                      output_invalid       = 4
                      overflow             = 5
                      type_invalid         = 6
                      units_missing        = 7
                      unit_in_not_found    = 8
                      unit_out_not_found   = 9
                      OTHERS               = 10.
                ENDIF.
                IF sy-subrc IS INITIAL.
                  lw_lqua-verme = lv_qty_out.
                ELSE.
                  PERFORM f_append_msg_to_mail_3 USING  p_matnr
                                                       l_compqty
                                                       lw_data
                                                       lw_resb.
                  lv_error = 'X'.
                ENDIF.
              ENDIF.

              IF ls_zpp_trace_su_con-nista_in > lw_lqua-verme.
                ls_zpp_trace_su_con-nista_in = lw_lqua-verme.
              ENDIF.

              IF ls_zpp_trace_su_con-nista_in >= l_compqty.
                lw_item-entry_qnt = l_compqty.

                APPEND lw_item TO lt_item.
*                CLEAR l_compqty.

                lw_item_app-material = lw_item-material.
                lw_item_app-plant = lw_item-plant.
                lw_item_app-stge_loc = lw_item-stge_loc.
                lw_item_app-batch = lw_item-batch.
                lw_item_app-move_type = lw_item-move_type.
                lw_item_app-entry_uom = lw_item-entry_uom.
                lw_item_app-orderid = lw_item-orderid.
                lw_item_app-entry_qnt = lw_item-entry_qnt.
                lw_item_app-vlenr = ls_zpp_trace_su_con-lenum_in.
*              ENDIF.

                APPEND lw_item_app TO lt_item_app.

*              record to update the table zpp_trace_su_con.
                IF ls_zpp_trace_su_con-nista_in = l_compqty.
                  lw_trace_del = ls_zpp_trace_su_con.
                  APPEND lw_trace_del TO lt_trace_del.
                ELSE.
                  lw_trace_mod = ls_zpp_trace_su_con.
                  lw_trace_mod-nista_in = ls_zpp_trace_su_con-nista_in - l_compqty.
                  APPEND lw_trace_mod TO lt_trace_mod.
                ENDIF.

                CLEAR lw_item_app.
                CLEAR lw_item.
                CLEAR l_compqty.
                EXIT.
              ELSE.
                lw_item-entry_qnt = ls_zpp_trace_su_con-nista_in.
                l_compqty = l_compqty - ls_zpp_trace_su_con-nista_in.
*                IF lt_item IS NOT INITIAL.
                IF lw_item IS NOT INITIAL.
                  APPEND lw_item TO lt_item.
                ENDIF.

                lw_item_app-material = lw_item-material.
                lw_item_app-plant = lw_item-plant.
                lw_item_app-stge_loc = lw_item-stge_loc.
                lw_item_app-batch = lw_item-batch.
                lw_item_app-move_type = lw_item-move_type.
                lw_item_app-entry_uom = lw_item-entry_uom.
                lw_item_app-orderid = lw_item-orderid.
                lw_item_app-entry_qnt = lw_item-entry_qnt.
                lw_item_app-vlenr = ls_zpp_trace_su_con-lenum_in.

                IF lw_item_app IS NOT INITIAL.
                  APPEND lw_item_app TO lt_item_app.
                ENDIF.


                CLEAR lw_item_app.
                CLEAR lw_item.

*      Store the ZPP_TRACE_SU_CON record to be delated form the traceability table in case all the quantity is consumed.
                lw_trace_del = ls_zpp_trace_su_con.
                IF lw_trace_del IS NOT INITIAL.
                  APPEND lw_trace_del TO lt_trace_del.
                ENDIF.

*              IF l_compqty = 0.
*                EXIT.
*              ENDIF.
              ENDIF.
            ENDIF.
          ENDLOOP.

          IF l_compqty > 0.
            PERFORM f_append_msg_to_mail_3 USING p_matnr
                                                 l_compqty
                                                 lw_data
                                                 lw_resb.
            lv_error = 'X'.
          ENDIF.
        ENDIF.
      ENDLOOP.
    ENDIF.

    IF lv_error IS INITIAL.

      READ TABLE lt_item INTO lw_item INDEX 1.
      PERFORM unlock_fm USING lw_item-reserv_no.

      CALL FUNCTION 'BAPI_GOODSMVT_CREATE'
        EXPORTING
          goodsmvt_header  = lw_header
          goodsmvt_code    = l_gm_code
        IMPORTING
          materialdocument = c_matdoc
          matdocumentyear  = c_docyear
        TABLES
          goodsmvt_item    = lt_item
          return           = lt_return.

      IF c_matdoc IS NOT INITIAL.
        IF lt_trace_mod[] IS NOT INITIAL .
          MODIFY zpp_trace_su_con FROM TABLE lt_trace_mod.
        ENDIF.

        IF lt_trace_del[] IS NOT INITIAL .
          DELETE zpp_trace_su_con FROM TABLE lt_trace_del.
        ENDIF.

        CALL FUNCTION 'BAPI_TRANSACTION_COMMIT'
          EXPORTING
            wait = 'X'.
      ELSE.
        lv_error = 'X'.
        CALL FUNCTION 'BAPI_TRANSACTION_ROLLBACK'.
        PERFORM f_store_error_record USING lw_data
                                           lt_item.
        PERFORM f_append_msg_to_mail_2 USING p_matnr
                                             lw_data
                                       CHANGING lt_item
                                                lt_return.
      ENDIF.
    ENDIF.
  ENDIF.
  "End of ins  S01K910878 24/04/2020 E.M.

ENDFORM.
