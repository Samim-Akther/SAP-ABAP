      objecttable        = 'MCH1'
      key_date           = sy-datlo
      initial_charact    = 'X'
    TABLES
      t_class            = lt_class
      t_objectdata       = lt_objdata
    EXCEPTIONS
      no_classification  = 1
      no_classtypes      = 2
      invalid_class_type = 3
      OTHERS             = 4.
  IF sy-subrc <> 0.
*----------------------------------------------------------------------*
* SEND AN ERROR MAIL TO ALL RECEIVERS OF THE DISTRIBUTION LIST
*----------------------------------------------------------------------*
    c_error = 'X'.
  ENDIF.


