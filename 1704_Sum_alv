***************
* USER COMMAND
***************
FORM user_command USING ucomm TYPE sy-ucomm
                        selfield TYPE slis_selfield.
  CASE ucomm.
    WHEN '&IC1'.
      READ TABLE outtable INTO ls_order INDEX selfield-tabindex.
      IF sy-subrc EQ 0.
        IF selfield-fieldname = 'MATNR' .
          SET PARAMETER ID 'MAT' FIELD ls_order-matnr.
          CALL TRANSACTION 'MM03' AND SKIP FIRST SCREEN.
        ENDIF.
        IF selfield-fieldname = 'VBELN' .

          AUTHORITY-CHECK OBJECT 'S_TCODE' ID 'TCD' FIELD 'VA03'.
          IF sy-subrc EQ 0.
            SET PARAMETER ID 'AUN' FIELD ls_order-vbeln.
            CALL TRANSACTION 'VA03' AND SKIP FIRST SCREEN.
          ELSE.
            MESSAGE e208(00) WITH text-013.
          ENDIF.
        ENDIF.
      ENDIF.
  ENDCASE.
ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  F_FILL_TAB_FIELD_LEN
*&---------------------------------------------------------------------*
FORM f_fill_tab_field_len  USING    i_outtab
                           CHANGING ct_field_len TYPE ty_t_field_len.
  DATA lo_rtti_struct TYPE REF TO cl_abap_structdescr.
  DATA(lo_typedescr) = cl_abap_structdescr=>describe_by_data( i_outtab ).
  IF ( lo_typedescr->kind = cl_abap_typedescr=>kind_struct ).
    lo_rtti_struct ?= lo_typedescr.
    DATA(lt_dfies) = cl_salv_data_descr=>read_structdescr( lo_rtti_struct ).
  ENDIF.

  LOOP AT lt_dfies INTO DATA(ls_dfies).
    ASSIGN COMPONENT ls_dfies-fieldname OF STRUCTURE i_outtab TO FIELD-SYMBOL(<fs_field>).
    IF <fs_field> IS ASSIGNED.
      CHECK ls_dfies-datatype = 'CHAR'.
      READ TABLE ct_field_len ASSIGNING FIELD-SYMBOL(<fs_field_len>) WITH KEY fieldname = ls_dfies-fieldname.
      IF sy-subrc = 0.
        DATA(len) = strlen( <fs_field> ).
        IF <fs_field_len>-outputlen LT len.
          <fs_field_len>-outputlen = len.
        ENDIF.
        UNASSIGN <fs_field_len>.
      ELSE.
        APPEND INITIAL LINE TO ct_field_len ASSIGNING <fs_field_len>.
        IF <fs_field_len> IS ASSIGNED.
          <fs_field_len>-fieldname = ls_dfies-fieldname.
          <fs_field_len>-outputlen = strlen( <fs_field> ).
          UNASSIGN <fs_field_len>.
        ENDIF.
      ENDIF.
      UNASSIGN <fs_field>.
    ENDIF.
  ENDLOOP.

ENDFORM.
