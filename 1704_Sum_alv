*&---------------------------------------------------------------------*
*&      Form  POSTAB_VALUES_SUPP
*&---------------------------------------------------------------------*
*       Zulieferspezifische Ermittlung von POSTAB-Daten
*----------------------------------------------------------------------*
*      -->P_DA_XVBEP  text                                             *
*      -->P_POSTAB-OLFMNG  text                                        *
*      -->P_POSTAB-LFDAT_1  text                                       *
*----------------------------------------------------------------------*
FORM postab_values_supp TABLES p_xvbep STRUCTURE vbepvb
                               p_xvbfa STRUCTURE vbfavb
                        USING  p_postab-olfmng
                               p_postab-lfdat_1
                               p_postab-kwmeng
                               p_postab-kbmeng.

  DATA: p_xvbap          LIKE vbapvb OCCURS 0 WITH HEADER LINE,
        p_xvbup          LIKE vbupvb OCCURS 0 WITH HEADER LINE,
        da_bmeng_planned LIKE vbep-bmeng.

  CLEAR: p_postab-olfmng,
         p_postab-kwmeng,
         p_postab-kbmeng,
         p_postab-lfdat_1.

* P_XVBAP aufbauen
  p_xvbap = vbap.
  APPEND p_xvbap.
* P_XVBUP aufbauen
  p_xvbup = vbup.
  APPEND p_xvbup.

* offene Mengen ermitteln
  CALL FUNCTION 'RV_SCHEDULE_CHECK_DELIVERIES'
    EXPORTING
      fbeleg                  = vbap-vbeln
      fposnr                  = vbap-posnr
      fs073_alt               = 'X'
    TABLES
      fvbfa                   = p_xvbfa
      fvbup                   = p_xvbup
      fxvbep                  = p_xvbep
      fvbap                   = p_xvbap
    EXCEPTIONS
      fehler_bei_lesen_fvbup  = 1
      fehler_bei_lesen_fxvbep = 2
                                OTHERS.
* compute OLFMNG of ALL schedule lines, but KWMENG only from delivery
* schedules and KBMENG from planned schedules, if there are some, if
* not, take delivery schedules, too.              ( see note 483798 ! )
  LOOP AT p_xvbep WHERE vbeln EQ vbap-vbeln AND
                        posnr EQ vbap-posnr.
    IF NOT p_xvbep-olfmng IS INITIAL.
      IF p_postab-lfdat_1 IS INITIAL.
        p_postab-lfdat_1 = p_xvbep-edatu.
      ELSE.
        IF p_xvbep-edatu LT p_postab-lfdat_1.
          p_postab-lfdat_1 = p_xvbep-edatu.
        ENDIF.
      ENDIF.
    ENDIF.
    p_postab-olfmng = p_postab-olfmng + p_xvbep-olfmng.
    IF p_xvbep-abart = '1'.
      p_postab-kwmeng = p_postab-kwmeng + p_xvbep-wmeng.
      p_postab-kbmeng = p_postab-kbmeng + p_xvbep-bmeng.
    ENDIF.
    IF p_xvbep-abart = '5'.
      da_bmeng_planned = da_bmeng_planned + p_xvbep-bmeng.
    ENDIF.
  ENDLOOP.
  IF da_bmeng_planned GT 0.
    p_postab-kbmeng = da_bmeng_planned.
  ENDIF.


ENDFORM.                               " POSTAB_VALUES_SUPP
