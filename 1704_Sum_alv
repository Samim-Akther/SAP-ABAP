       FROM kna1
      INTO TABLE @DATA(lt_kna)
      FOR ALL ENTRIES IN @lt_vbpa
      WHERE kunnr = @lt_vbpa-kunnr.
  ENDIF.
  SORT lt_kna BY kunnr.
  SORT lt_mard BY matnr werks."added by samim
  SORT lt_vbfa BY vbelv posnv.
  "EOC Ashish 14/11/2025.

  LOOP AT postab WHERE lfdat_1 IN s_firdt.
    outtab-matnr = postab-matnr.
    CALL FUNCTION 'CONVERSION_EXIT_CUNIT_OUTPUT' "added by samim 29/01/26
      EXPORTING
        input    = postab-meins
        language = sy-langu
      IMPORTING
        output   = outtab-base_uom.
    "BOC CR 1704 Ashish 14/11/25.
    READ TABLE lt_vbpa ASSIGNING FIELD-SYMBOL(<fs_vbpa>)
            WITH KEY vbeln = postab-vbeln
                     parvw = p_parvw_we BINARY SEARCH.
    IF sy-subrc = 0.
      outtab-shipto = <fs_vbpa>-kunnr.
    ENDIF.
    READ TABLE lt_kna ASSIGNING FIELD-SYMBOL(<fs_kna>)
        WITH KEY kunnr = <fs_vbpa>-kunnr BINARY SEARCH.
    IF sy-subrc = 0.
      CONCATENATE <fs_kna>-name1
                  <fs_kna>-name2
             INTO outtab-shipnam.
    ENDIF.
    outtab-custmat = postab-kdmat.
    READ TABLE lt_vbfa ASSIGNING FIELD-SYMBOL(<fs_vbfa>)
              WITH KEY vbelv = postab-vbeln posnv = postab-posnr
              BINARY SEARCH.
    IF sy-subrc = 0.
      outtab-invqty = REDUCE #(
                  INIT x = 0
                  FOR row2 IN lt_vbrp
                  WHERE ( aubel = <fs_vbfa>-vbelv
                          AND posnr = <fs_vbfa>-posnn )
                  NEXT x = x + row2-fkimg ).

    ENDIF.
    READ TABLE lt_mard_sum ASSIGNING FIELD-SYMBOL(<fs_mard>)
      WITH KEY matnr = postab-matnr
               werks = postab-werks
               BINARY SEARCH.
    IF sy-subrc = 0.
      outtab-labst = <fs_mard>-labst.
    ENDIF.
    "EOC Ashish 14/11/25.
    CLEAR lv_objek.
    FREE: lt_objectdata, lt_class.
    lv_objek = postab-matnr.
    CALL FUNCTION 'CLAF_CLASSIFICATION_OF_OBJECTS'
      EXPORTING
        classtype          = '001'
        object             = lv_objek
        objecttable        = 'MARA'
        initial_charact    = abap_false
      TABLES
        t_class            = lt_class
        t_objectdata       = lt_objectdata
*       I_SEL_CHARACTERISTIC       =
      EXCEPTIONS
        no_classification  = 1
        no_classtypes      = 2
        invalid_class_type = 3
        OTHERS             = 4.

    READ TABLE lt_objectdata INTO DATA(ls_objectdata) WITH KEY atnam = 'PRODUCT_TYPE'.
    IF sy-subrc = 0.
      DATA: lv_matnr TYPE mara-matnr.
      outtab-pr_type = ls_objectdata-ausp1.
      CALL FUNCTION 'CONVERSION_EXIT_MATN1_INPUT'
        EXPORTING
          input        = outtab-pr_type
        IMPORTING
          output       = lv_matnr
        EXCEPTIONS
          length_error = 1
          OTHERS       = 2.
      SELECT SINGLE maktx INTO outtab-pr_type_des
        FROM makt WHERE matnr = lv_matnr AND spras = sy-langu.
    ENDIF.

    READ TABLE lt_objectdata INTO ls_objectdata WITH KEY atnam = 'GEOMETRY'.
    IF sy-subrc = 0.
      outtab-geometry = ls_objectdata-ausp1.
    ENDIF.

    READ TABLE lt_objectdata INTO ls_objectdata WITH KEY atnam = 'LINE_1_TECH'.
    IF sy-subrc = 0.
      outtab-line_1_tech = ls_objectdata-ausp1.
    ENDIF.
    READ TABLE lt_objectdata INTO ls_objectdata WITH KEY atnam = 'LINE_2_SALES'.
    IF sy-subrc = 0.
      outtab-line_2_sales = ls_objectdata-ausp1.
    ENDIF.
    READ TABLE lt_objectdata INTO ls_objectdata WITH KEY atnam = 'TYPE_1_TECH'.
    IF sy-subrc = 0.
      outtab-type_1_tech = ls_objectdata-ausp1.
    ENDIF.
    READ TABLE lt_objectdata INTO ls_objectdata WITH KEY atnam = 'TYPE_2_SALES'.
    IF sy-subrc = 0.
      outtab-type_2_sales = ls_objectdata-ausp1.
    ENDIF.

    outtab-arktx = postab-arktx.
    outtab-kunnr = postab-kunnr.
    SELECT SINGLE name1 INTO outtab-name1
      FROM kna1 WHERE kunnr = postab-kunnr.
* outtab-name1 = postab-name1.
    outtab-vbeln = postab-vbeln.
    outtab-posnr = postab-posnr.
    outtab-bstnk = postab-bstnk.   " PO Number
    outtab-lfdat_1 = postab-lfdat_1.  " first delivery date
    outtab-kwmeng = postab-kwmeng.
    outtab-kbmeng = postab-kbmeng.
    outtab-olfmng = postab-olfmng.
    outtab-vrkme = postab-vrkme. " sales unit
    READ TABLE lt_data INTO DATA(ls_data) WITH KEY vbeln = postab-vbeln
                                                   posnr = postab-posnr.
    IF sy-subrc = 0.
      outtab-netwr = ls_data-netwr.
      outtab-opnpr = ls_data-netwr / postab-kwmeng * outtab-olfmng .
      outtab-waerk = postab-waerk.
    ENDIF.
    PERFORM f_fill_tab_field_len USING outtab CHANGING gt_field_len.
    "BOC CR 1704 Ashish 17/11/25.
    IF s_party[] IS NOT INITIAL.
      IF outtab-shipto NOT IN s_party.
        CONTINUE.
      ENDIF.
    ENDIF.
    "EOC Ashish 17/11/25.
    APPEND outtab TO outtable.
    CLEAR outtab.
  ENDLOOP.


