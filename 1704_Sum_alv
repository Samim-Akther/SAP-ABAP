*---------------------------------------------------------------------*
*       FORM POSTAB_AUFBAUEN                                          *
*---------------------------------------------------------------------*
*                                                                     *
*---------------------------------------------------------------------*
FORM postab_aufbauen USING it_data TYPE tt_data_merge.

  DATA:    BEGIN OF xvbep OCCURS 0.
          INCLUDE STRUCTURE vbepvb.
  DATA:    END OF xvbep.
  DATA:    xvbfa LIKE vbfavb OCCURS 0.
  DATA:    BEGIN OF xvbapf OCCURS 0.
          INCLUDE STRUCTURE vbapf.
  DATA:    END OF xvbapf,
  da_posnr LIKE vbap-posnr,
    da_omeng LIKE vbap-kwmeng,
    da_pssum LIKE vbap-kwmeng,
    da_lines LIKE sy-tfill.
  DATA: lv_vbeln TYPE vbap-vbeln,
        lv_posnr TYPE vbap-posnr.
  DATA: lt_vbfa TYPE SORTED TABLE OF vbfa WITH NON-UNIQUE KEY vbelv posnv,
        lt_data LIKE it_data.

  TYPES:BEGIN OF ty_mara,
          matnr   TYPE matnr,
          sgt_rel TYPE sgt_rel,
          meins   TYPE meins, "added by samim
        END OF ty_mara,

        BEGIN OF ty_marc,
          matnr     TYPE matnr,
          werks     TYPE werks_d,
          sgt_covs  TYPE sgt_covs,
          sgt_statc TYPE sgt_statc,
        END OF ty_marc.

  DATA: lt_mara   TYPE TABLE OF ty_mara,
        ls_mara   TYPE ty_mara,
        lt_marc   TYPE TABLE OF ty_marc,
        ls_marc   TYPE ty_marc,
        lv_flag   TYPE c,
        lv_r_code TYPE sy-subrc.

  CONSTANTS: lc_r      TYPE c VALUE 'R',
             lc_x      TYPE c VALUE 'X',
             lc_var(3) TYPE c VALUE 'VAR'.

  FIELD-SYMBOLS: <ls_data> LIKE LINE OF it_data,
                 <ls_vbep> LIKE LINE OF it_data,
                 <ls_vbfa> LIKE LINE OF lt_vbfa.


  CHECK it_data IS NOT INITIAL.
  lt_data = it_data.
  DELETE ADJACENT DUPLICATES FROM lt_data COMPARING vbeln posnr.
  SELECT * INTO TABLE lt_vbfa FROM vbfa
     FOR ALL ENTRIES IN lt_data
     WHERE vbelv EQ lt_data-vbeln
       AND posnv EQ lt_data-posnr
         ORDER BY PRIMARY KEY.
  IF cl_ops_switch_check=>sfsw_segmentation( ) EQ abap_on.
    SELECT matnr
           sgt_rel
           meins "added by samim
       FROM mara
       INTO CORRESPONDING FIELDS OF TABLE lt_mara
       FOR ALL ENTRIES IN lt_data
     WHERE matnr =  lt_data-matnr.

    SELECT matnr
           werks
           sgt_covs
           sgt_statc
       FROM marc
       INTO CORRESPONDING FIELDS OF TABLE lt_marc
       FOR ALL ENTRIES IN lt_data
     WHERE matnr =  lt_data-matnr
      AND  werks =  lt_data-werks.

  ENDIF.
  FREE lt_data.

  LOOP AT it_data ASSIGNING <ls_data>.

    CLEAR: postab,
           da_posnr,
           da_omeng,
           da_pssum,
           da_lines,
           vbap,
           vbup.

    MOVE-CORRESPONDING <ls_data> TO vbap.
    MOVE-CORRESPONDING <ls_data> TO vbup.
    IF cl_ops_switch_check=>sfsw_segmentation( ) EQ abap_on.
* If req cat is missing check if it is required, no need to show in list
      CLEAR:lv_flag,lv_r_code,ls_marc,ls_mara.
      READ TABLE lt_mara INTO ls_mara WITH KEY matnr = vbap-matnr.
      IF ls_mara-sgt_rel = lc_x.
        READ TABLE lt_marc INTO ls_marc WITH KEY matnr = vbap-matnr.
* Check coverage strategy fixed and is assigned to material
        IF ls_marc-sgt_statc = lc_x AND
           ls_marc-sgt_covs IS NOT INITIAL.
          CALL FUNCTION 'SGTG_CHECK_CAT_VALID_CONDENSE'
            EXPORTING
              iv_plant        = vbap-werks
              iv_covs         = ls_marc-sgt_covs
              iv_appl         = lc_r
              iv_cfun         = lc_var
              iv_cat_value    = vbap-sgt_rcat
            IMPORTING
              ev_r_code       = lv_r_code
            EXCEPTIONS
              eliminate_error = 1
              internal_error  = 2
              OTHERS          = 3.
* Requirement category is needed.
          IF lv_r_code NE 0.
            lv_flag = lc_x.
          ENDIF.
        ENDIF.
      ENDIF.
      CHECK lv_flag NE lc_x .
    ENDIF.
    IF lv_vbeln EQ <ls_data>-vbeln AND
       lv_posnr EQ <ls_data>-posnr.
      CONTINUE.
    ENDIF.
    lv_vbeln = <ls_data>-vbeln.
    lv_posnr = <ls_data>-posnr.
    "BOC CR 1704 Ashish 14/11/2025.
    postab-kdmat = <ls_data>-kdmat.
    postab-matnr = <ls_data>-matnr.
    postab-meins = VALUE #( lt_mara[ matnr = <ls_data>-matnr ]-meins OPTIONAL ).
    postab-werks = <ls_data>-werks.
    postab-lgort = <ls_data>-lgort.
    "EOC Ashish 14/11/2025.

* Product selection - Positionen nicht anzeigen
    da_posnr = <ls_data>-posnr.
    IF NOT <ls_data>-uepos IS INITIAL AND
           <ls_data>-prosa EQ 'B'.
      da_posnr = <ls_data>-uepos.

* Sum up all lower items
      IF <ls_data>-rfsta EQ 'B' OR
         <ls_data>-rfgsa EQ 'B' OR
         <ls_data>-lfsta EQ 'B' OR
         <ls_data>-lfgsa EQ 'B'.
        SELECT SUM( klmeng ) INTO da_pssum
               FROM vbap WHERE vbeln = <ls_data>-vbeln
                      AND posnr < <ls_data>-posnr
                      AND uepos = <ls_data>-uepos
                    AND prosa = 'B'.
      ENDIF.
    ENDIF.
    CLEAR: xvbep[], xvbep.
    LOOP AT it_data ASSIGNING <ls_vbep>
      WHERE vbeln = <ls_data>-vbeln
        AND posnr = <ls_data>-posnr
        AND etenr IS NOT INITIAL.

*      IF NOT <ls_vbep>-bdart IS INITIAL OR
*         NOT <ls_vbep>-plart IS INITIAL.
      da_lines = da_lines + 1.
      MOVE-CORRESPONDING <ls_vbep> TO xvbep.
      APPEND xvbep.
** Bei Lieferplänen mit Abrufen müssen auch die nicht bedarfsrelevanten
** Einteilungen zur Errechnung der Abruf-FZ übernommen werden.
*      ELSEIF NOT <ls_data>-abdis IS INITIAL.
*        IF NOT <ls_vbep>-bdart IS INITIAL OR
*           NOT <ls_vbep>-plart IS INITIAL.
*          da_lines = da_lines + 1.
*        ENDIF.
*        MOVE-CORRESPONDING <ls_vbep> TO xvbep.
*        APPEND xvbep.
*      ENDIF.
    ENDLOOP.
    SORT xvbep BY vbeln posnr mbdat etenr.
    CHECK da_lines > 0.
    IF <ls_data>-abdis IS INITIAL.
      REFRESH xvbfa.
      LOOP AT lt_vbfa ASSIGNING <ls_vbfa>
        WHERE vbelv EQ <ls_data>-vbeln
          AND posnv EQ da_posnr.
        APPEND <ls_vbfa> TO xvbfa.
      ENDLOOP.
      CALL FUNCTION 'RV_XVBAPF_CREATE'
        EXPORTING
          vbeln   = <ls_data>-vbeln
        TABLES
          fxvbfa  = xvbfa
          fxvbapf = xvbapf.

      IF xvbapf-vbeln NE <ls_data>-vbeln OR xvbapf-posnr NE <ls_data>-posnr.
        LOOP AT xvbapf WHERE vbeln = <ls_data>-vbeln AND posnr = <ls_data>-posnr.
          EXIT.
        ENDLOOP.
        IF sy-subrc NE 0.
          CLEAR xvbapf.
        ENDIF.
      ENDIF.
    ENDIF.

* Name des Auftraggebers lesen (in KNA1)
    PERFORM partnername_lesen USING <ls_data>-kunnr space.

* Daten übergeben
    MOVE-CORRESPONDING <ls_data> TO postab.
    postab-name1 = kna1-name1.
    IF <ls_data>-lprio IS INITIAL.
      postab-lprio      = '99'.
    ENDIF.

* POSTAB-Werte bei Zulieferabwicklung ermitteln
    IF NOT <ls_data>-abdis IS INITIAL.
      PERFORM postab_values_supp TABLES xvbep
                                        xvbfa
                                 USING postab-olfmng
                                       postab-lfdat_1
                                       postab-kwmeng
                                       postab-kbmeng.
    ELSE.
* Errechnung der noch offenen Menge und des ersten Lieferdatums
      IF <ls_data>-kzfme IS INITIAL.
        postab-olfmng = ( xvbapf-erlmenge  + xvbapf-erlmenge_l ) * quan_1
                      * <ls_data>-umvkn / <ls_data>-umvkz.
      ELSE.
        postab-olfmng = ( xvbapf-erlmengev + xvbapf-erlmengelv ) * quan_1.
      ENDIF.
      postab-olfmng       = postab-olfmng - da_pssum.
      IF NOT da_pssum IS INITIAL.
        CHECK postab-olfmng > 0.
      ENDIF.
      da_omeng            = postab-olfmng.

* Offene Menge berechnen: bei fixierten Aufträgen aus bestätigter Menge
      IF <ls_data>-fixmg NE space.
        postab-olfmng       = postab-kbmeng - postab-olfmng.
      ELSE.
        postab-olfmng       = postab-kwmeng - postab-olfmng.
      ENDIF.

* Lieferdatum der 1. offenen Menge berechnen

      LOOP AT xvbep WHERE cmeng > 0.
        IF da_omeng GE xvbep-cmeng.
          da_omeng        = da_omeng - xvbep-cmeng.
        ELSE.
          xvbep-cmeng     = xvbep-cmeng - da_omeng.
          postab-lfdat_1  = xvbep-edatu.
          EXIT.
        ENDIF.
      ENDLOOP.
    ENDIF.

* nur relevante Belegpositionen mit offenen Mengen aus
* Zulieferlieferplänen übernehmen
    IF NOT <ls_data>-abdis IS INITIAL AND
         postab-olfmng IS INITIAL.
      CLEAR postab.
    ELSE.
* Senkrechter Trennstrich
      postab-vline        = sy-vline.

      DESCRIBE TABLE postab LINES da_lines."JOJO

      postab-selkz = ' '.
      postab-activ = '0'.
      postab-zaehl = da_lines + 1.       "JOJO
      APPEND postab.
    ENDIF.
  ENDLOOP.

ENDFORM.                    "POSTAB_AUFBAUEN
*eject

